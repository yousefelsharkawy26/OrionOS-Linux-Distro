#!/bin/bash
# OrionOS ISO installer
# Launched from live environment to install OrionOS

set -euo pipefail

INSTALLER_VERSION="1.0.0"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

print_header() {
    clear
    echo -e "${CYAN}${BOLD}"
    cat << 'LOGO'
    ___  ____  _____ _   _ ______   __
   / _ \|  _ \| ____| \ | | __ \ \ / /
  | | | | |_) |  _| |  \| |  _ \\ V /
  | |_| |  __/| |___| |\  | |_) || |
   \___/|_|   |_____|_| \_|____/ |_|

LOGO
    echo -e "${NC}"
    echo -e "  ${BOLD}OrionOS Installer v${INSTALLER_VERSION}${NC}"
    echo -e "  ─────────────────────────────────────"
    echo ""
}

print_step() {
    echo -e "\n${YELLOW}${BOLD}[STEP]${NC} $1"
}

print_success() {
    echo -e "${GREEN}  ✓ $1${NC}"
}

print_error() {
    echo -e "${RED}  ✗ $1${NC}"
}

print_info() {
    echo -e "${BLUE}  → $1${NC}"
}

# ─────────────────────────────────────────────
# Step 1: Select target disk
# ─────────────────────────────────────────────
select_disk() {
    print_step "Select installation disk"

    echo -e "\n  Available disks:\n"
    lsblk -dpno NAME,SIZE,MODEL | grep -v "loop\|sr\|ram"
    echo ""

    DISKS=($(lsblk -dpno NAME | grep -v "loop\|sr\|ram"))
    if [[ ${#DISKS[@]} -eq 0 ]]; then
        print_error "No disks found"
        exit 1
    fi

    if [[ ${#DISKS[@]} -eq 1 ]]; then
        TARGET_DISK="${DISKS[0]}"
        print_info "Auto-selected: ${TARGET_DISK}"
    else
        read -rp "  Enter disk path (e.g., /dev/sda): " TARGET_DISK
    fi

    if [[ ! -b "$TARGET_DISK" ]]; then
        print_error "Disk not found: $TARGET_DISK"
        exit 1
    fi

    DISK_SIZE=$(lsblk -bndo SIZE "$TARGET_DISK")
    print_info "Disk: ${TARGET_DISK} ($(numfmt --to=iec $DISK_SIZE))"
}

# ─────────────────────────────────────────────
# Step 2: Partitioning
# ─────────────────────────────────────────────
partition_disk() {
    print_step "Partitioning disk"

    print_info "WARNING: All data on ${TARGET_DISK} will be destroyed!"
    read -rp "  Continue? [y/N]: " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        print_info "Installation cancelled"
        exit 0
    fi

    # Wipe disk
    wipefs -af "$TARGET_DISK" >/dev/null 2>&1
    sgdisk --zap-all "$TARGET_DISK" >/dev/null 2>&1

    # Create partition table
    parted -s "$TARGET_DISK" mklabel gpt

    # EFI System Partition (512MB)
    parted -s "$TARGET_DISK" mkpart ESP fat32 1MiB 513MiB
    parted -s "$TARGET_DISK" set 1 esp on

    # Boot partition (1GB)
    parted -s "$TARGET_DISK" mkpart boot ext4 513MiB 1537MiB

    # Root partition (remaining)
    parted -s "$TARGET_DISK" mkpart root btrfs 1537MiB 100%

    # Wait for partition device nodes
    partprobe "$TARGET_DISK"
    sleep 2

    # Determine partition naming
    if [[ "$TARGET_DISK" == *"nvme"* ]] || [[ "$TARGET_DISK" == *"mmcblk"* ]]; then
        PART_PREFIX="${TARGET_DISK}p"
    else
        PART_PREFIX="${TARGET_DISK}"
    fi

    ESP_PART="${PART_PREFIX}1"
    BOOT_PART="${PART_PREFIX}2"
    ROOT_PART="${PART_PREFIX}3"

    print_success "Partition table created"

    # Format partitions
    print_step "Formatting partitions"

    mkfs.fat -F32 -n "ORIONOS_ESP" "$ESP_PART"
    print_success "ESP: FAT32 ${ESP_PART}"

    mkfs.ext4 -L "orionos-boot" "$BOOT_PART"
    print_success "Boot: ext4 ${BOOT_PART}"

    mkfs.btrfs -f -L "orionos-root" "$ROOT_PART"
    print_success "Root: Btrfs ${ROOT_PART}"

    # Create Btrfs subvolumes
    print_step "Creating Btrfs subvolumes"

    mount -t btrfs "$ROOT_PART" /mnt

    btrfs subvolume create /mnt/@
    btrfs subvolume create /mnt/@home
    btrfs subvolume create /mnt/@var
    btrfs subvolume create /mnt/@snapshots
    btrfs subvolume create /mnt/@log
    btrfs subvolume create /mnt/@cache

    umount /mnt

    print_success "Subvolumes created: @, @home, @var, @snapshots, @log, @cache"
}

# ─────────────────────────────────────────────
# Step 3: Mount filesystems
# ─────────────────────────────────────────────
mount_filesystems() {
    print_step "Mounting filesystems"

    # Mount root subvolume
    mount -t btrfs -o subvol=@,compress=zstd,ssd,noatime "$ROOT_PART" /mnt

    # Create mount points
    mkdir -p /mnt/{boot,boot/efi,home,var,var/log,var/cache,.snapshots}

    # Mount subvolumes
    mount -t btrfs -o subvol=@home,compress=zstd,ssd,noatime "$ROOT_PART" /mnt/home
    mount -t btrfs -o subvol=@var,compress=zstd,ssd,noatime "$ROOT_PART" /mnt/var
    mount -t btrfs -o subvol=@snapshots,compress=zstd,ssd,noatime "$ROOT_PART" /mnt/.snapshots
    mount -t btrfs -o subvol=@log,compress=zstd,ssd,noatime "$ROOT_PART" /mnt/var/log
    mount -t btrfs -o subvol=@cache,compress=zstd,ssd,noatime "$ROOT_PART" /mnt/var/cache

    # Mount boot and ESP
    mount "$BOOT_PART" /mnt/boot
    mount "$ESP_PART" /mnt/boot/efi

    print_success "Filesystems mounted"

    # Export for later use
    export INSTALL_ROOT="/mnt"
    export TARGET_DISK ESP_PART BOOT_PART ROOT_PART
}

# ─────────────────────────────────────────────
# Step 4: Configure system
# ─────────────────────────────────────────────
configure_system() {
    print_step "Configuring system"

    # fstab
    print_info "Generating fstab"
    genfstab -U /mnt >> /mnt/etc/fstab

    # Mirrorlist
    print_info "Configuring mirrors"
    reflector --country US,DE,NL --protocol https --sort rate --latest 5 \
        --save /mnt/etc/pacman.d/mirrorlist 2>/dev/null || true

    # Timezone
    print_info "Setting timezone to UTC"
    ln -sf /usr/share/zoneinfo/UTC /mnt/etc/localtime
    chroot /mnt hwclock --systohc

    # Locale
    print_info "Generating locales"
    echo "en_US.UTF-8 UTF-8" > /mnt/etc/locale.gen
    chroot /mnt locale-gen
    echo "LANG=en_US.UTF-8" > /mnt/etc/locale.conf

    # Hostname
    echo "orionos" > /mnt/etc/hostname

    print_success "System configured"
}

# ─────────────────────────────────────────────
# Step 5: Install packages
# ─────────────────────────────────────────────
install_packages() {
    print_step "Installing packages (this may take a while)"

    # Pacstrap
    pacstrap /mnt base base-devel linux linux-headers linux-firmware \
        btrfs-progs grub grub-btrfs snapper snap-pac \
        networkmanager iwd openssh curl wget \
        efibootmgr dosfstools os-prober \
        pipewire pipewire-pulse pipewire-jack wireplumber \
        bluez bluez-utils \
        sudo bash-completion

    print_success "Base packages installed"
}

# ─────────────────────────────────────────────
# Step 6: Bootloader
# ─────────────────────────────────────────────
install_bootloader() {
    print_step "Installing bootloader"

    # Generate fstab
    chroot /mnt systemctl enable NetworkManager

    # GRUB
    chroot /mnt grub-install --target=x86_64-efi --efi-directory=/boot/efi \
        --bootloader-id=OrionOS --removable
    chroot /mnt grub-install --target=i386-pc "$TARGET_DISK" 2>/dev/null || true

    # Configure GRUB
    chroot /mnt sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="quiet"/GRUB_CMDLINE_LINUX_DEFAULT="quiet btrfs compress=zstd ssd"/' /etc/default/grub
    chroot /mnt grub-mkconfig -o /boot/grub/grub.cfg

    print_success "GRUB installed"
}

# ─────────────────────────────────────────────
# Step 7: User setup
# ─────────────────────────────────────────────
create_user() {
    print_step "Creating user account"

    read -rp "  Enter username: " USERNAME
    if [[ -z "$USERNAME" ]]; then
        USERNAME="user"
    fi

    chroot /mnt useradd -m -G wheel,video,audio,storage -s /bin/bash "$USERNAME"
    echo "  Set password for ${USERNAME}:"
    chroot /mnt passwd "$USERNAME"

    # Sudo
    echo "%wheel ALL=(ALL) ALL" > /mnt/etc/sudoers.d/wheel
    chmod 440 /mnt/etc/sudoers.d/wheel

    print_success "User ${USERNAME} created"
}

# ─────────────────────────────────────────────
# Step 8: Enable services
# ─────────────────────────────────────────────
enable_services() {
    print_step "Enabling services"

    chroot /mnt systemctl enable NetworkManager.service
    chroot /mnt systemctl enable bluetooth.service
    chroot /mnt systemctl enable sshd.service
    chroot /mnt systemctl enable systemd-timesyncd.service
    chroot /mnt systemctl enable snapper.timer

    print_success "Services enabled"
}

# ─────────────────────────────────────────────
# Step 9: Cleanup and finish
# ─────────────────────────────────────────────
finalize() {
    print_step "Finalizing installation"

    # Unmount
    umount -R /mnt

    print_header
    echo -e "  ${GREEN}${BOLD}Installation Complete!${NC}\n"
    echo "  OrionOS has been installed to ${TARGET_DISK}"
    echo ""
    echo "  You can now reboot into your new system."
    echo "  Remove the installation media before rebooting."
    echo ""
    read -rp "  Reboot now? [y/N]: " do_reboot
    if [[ "$do_reboot" == "y" || "$do_reboot" == "Y" ]]; then
        reboot
    fi
}

# ─────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────
main() {
    print_header

    # Check if running as root
    if [[ $EUID -ne 0 ]]; then
        print_error "This installer must be run as root"
        echo "  Run: sudo orionos-installer"
        exit 1
    fi

    select_disk
    partition_disk
    mount_filesystems
    configure_system
    install_packages
    install_bootloader
    create_user
    enable_services
    finalize
}

main "$@"
