    # ==================================================================
    # GTK 4 Theme
    # ==================================================================
    install -d "$pkgdir/usr/share/themes/OrionOS-Dark/gtk-4.0"
    cp "$pkgdir/usr/share/themes/OrionOS-Dark/gtk-3.0/gtk.css" \
