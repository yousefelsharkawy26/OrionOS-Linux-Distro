/* OrionOS Dark GTK3 Theme */
/* Based on Catppuccin Macchiato with custom adjustments */

@define-color bg_color #1e2030;
@define-color fg_color #cad3f5;
@define-color base_color #24273a;
@define-color text_color #cad3f5;
@define-color selected_bg_color #8aadf4;
@define-color selected_fg_color #1e2030;
@define-color tooltip_bg_color #1e2030;
@define-color tooltip_fg_color #cad3f5;
@define-color accent_color #8aadf4;
@define-color accent_bg_color #363a4f;
@define-color button_bg_color #363a4f;
@define-color button_fg_color #cad3f5;
@define-color headerbar_bg_color #181926;
@define-color headerbar_fg_color #cad3f5;
@define-color menu_bg_color #1e2030;
@define-color menu_fg_color #cad3f5;
@define-color error_color #ed8796;
@define-color warning_color #eed49f;
@define-color success_color #a6da95;

* {
    background-color: @bg_color;
    color: @fg_color;
    border-color: #363a4f;
    outline-color: @accent_color;
    outline-width: 2px;
    outline-offset: -2px;
    -GtkWidget-focus-line-width: 2px;
    -GtkWidget-focus-padding: 2px;
}

