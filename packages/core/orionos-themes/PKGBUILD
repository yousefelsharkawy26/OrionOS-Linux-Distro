# Maintainer: Yousef Elsharkawy <yousefelsharkawy26@gmail.com>
pkgname=orionos-themes
pkgver=0.1.0
pkgrel=1
pkgdesc="OrionOS visual themes, icons, cursors, and branding"
arch=('any')
url="https://github.com/yousefelsharkawy26/OrionOS-Linux-Distro"
license=('GPL3')
depends=(
    'gtk3'
    'gtk4'
    'qt5-base'
    'qt6-base'
    'gdk-pixbuf2'
    'librsvg'
    'hicolor-icon-theme'
)
optdepends=(
    'papirus-icon-theme: Recommended icon theme'
    'bibata-cursor-theme: Recommended cursor theme'
    'orionos-desktop: Desktop environment integration'
)
conflicts=('orionos-themes-git')
provides=('orionos-themes')

package() {
    # Base directories
    install -d "$pkgdir/usr/share/themes"
    install -d "$pkgdir/usr/share/icons"
    install -d "$pkgdir/usr/share/plymouth/themes/orionos"
    install -d "$pkgdir/usr/share/sddm/themes/orionos"
    install -d "$pkgdir/usr/share/grub/themes/orionos"
    install -d "$pkgdir/usr/share/licenses/orionos-themes"
    install -d "$pkgdir/usr/share/doc/orionos-themes"
    install -d "$pkgdir/etc/skel/.config/gtk-3.0"
    install -d "$pkgdir/etc/skel/.config/gtk-4.0"
    install -d "$pkgdir/etc/skel/.config/Kvantum"

    # ==================================================================
    # GTK 3 Theme
    # ==================================================================
