    # ============================================
    # GTK3 Theme - OrionOS Dark
    # ============================================
    install -d "${pkgdir}/usr/share/themes/OrionOS-Dark/gtk-3.0"

    cat > "${pkgdir}/usr/share/themes/OrionOS-Dark/gtk-3.0/gtk.css" << 'EOF'
/* OrionOS Dark GTK3 Theme */

@define-color orion_bg #0F0F23;
@define-color orion_bg_secondary #1A1A3E;
