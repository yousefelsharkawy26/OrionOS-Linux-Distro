ORION_CORAL_DARK=#EE5A5A
ORION_GOLD=#FFD166
ORION_GREEN=#06D6A0
ORION_PINK=#F72585

# Neutral Colors
ORION_DARKEST=#0A0A1A
ORION_DARKER=#0F0F23
ORION_DARK=#1A1A3E
ORION_DARK_MID=#2A2A4A
ORION_MID=#4A4A6A
ORION_LIGHT_MID=#6A6A8A
