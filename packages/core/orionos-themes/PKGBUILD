    # ============================================
    # OrionOS Sound Theme
    # ============================================
    install -d "${pkgdir}/usr/share/sounds/OrionOS"

    cat > "${pkgdir}/usr/share/sounds/OrionOS/index.theme" << 'EOF'
[Sound Theme]
Name=OrionOS
Directories=stereo

[stereo]
OutputProfile=stereo
EOF

    # Sound event definitions
    cat > "${pkgdir}/usr/share/sounds/OrionOS/sounds.index" << 'EOF'
# OrionOS Sound Events
# These reference generated sounds that will be created during installation

desktop-login="stereo/desktop-login.oga"
desktop-logout="stereo/desktop-logout.oga"
dialog-information="stereo/dialog-information.oga"
dialog-warning="stereo/dialog-warning.oga"
dialog-error="stereo/dialog-error.oga"
dialog-question="stereo/dialog-question.oga"
message-new-instant="stereo/message-new-instant.oga"
message-sent-instant="stereo/message-sent-instant.oga"
complete="stereo/complete.oga"
notification-generic="stereo/notification-generic.oga"
notification-low="stereo/notification-low.oga"
window-minimized="stereo/window-minimized.oga"
window-maximized="stereo/window-maximized.oga"
window-close="stereo/window-close.oga"
window-switch="stereo/window-switch.oga"
window-new="stereo/window-new.oga"
EOF

    # Create sound generation script
    cat > "${pkgdir}/usr/share/orionos/scripts/generate-sounds.sh" << 'EOF'
#!/bin/bash
# Generate OrionOS sound theme using synthetic audio
# Requires: sox, ffmpeg

SOUND_DIR="/usr/share/sounds/OrionOS/stereo"
mkdir -p "$SOUND_DIR"

# System notification sound - subtle, modern
sox -n -r 44100 -c 2 "${SOUND_DIR}/notification-generic.oga" \
    synth 0.3 sine 800 sine 1200 \
    fade 0.01 0.3 0.1 \
    gain -10

# Login sound - ascending, welcoming
sox -n -r 44100 -c 2 "${SOUND_DIR}/desktop-login.oga" \
    synth 1.5 sine 400-800 sine 600-1200 \
    fade 0.05 1.5 0.3 \
    gain -8

# Logout sound - descending
sox -n -r 44100 -c 2 "${SOUND_DIR}/desktop-logout.oga" \
    synth 1.0 sine 800-400 sine 1200-600 \
    fade 0.05 1.0 0.3 \
    gain -8

# Error sound - low, alert
sox -n -r 44100 -c 2 "${SOUND_DIR}/dialog-error.oga" \
    synth 0.4 sine 200 sine 150 \
    fade 0.01 0.4 0.1 \
    gain -5

# Warning sound - attention
sox -n -r 44100 -c 2 "${SOUND_DIR}/dialog-warning.oga" \
    synth 0.5 sine 500 sine 700 \
    fade 0.01 0.5 0.15 \
    gain -7

# Success sound - pleasant
sox -n -r 44100 -c 2 "${SOUND_DIR}/complete.oga" \
    synth 0.6 sine 523-659-784 \
    fade 0.02 0.6 0.1 \
    gain -8

# Message sound - subtle
sox -n -r 44100 -c 2 "${SOUND_DIR}/message-new-instant.oga" \
    synth 0.2 sine 1000 sine 1400 \
    fade 0.01 0.2 0.05 \
    gain -12

# Window switch - minimal
sox -n -r 44100 -c 2 "${SOUND_DIR}/window-switch.oga" \
    synth 0.1 sine 600 \
    fade 0.005 0.1 0.02 \
    gain -15

chmod -R 644 "${SOUND_DIR}"/*.oga
EOF
    chmod +x "${pkgdir}/usr/share/orionos/scripts/generate-sounds.sh"

    # ============================================
    # Plymouth Boot Theme
    # ============================================
    cat > "${pkgdir}/usr/share/plymouth/themes/orionos/orionos.plymouth" << 'EOF'
[Plymouth Theme]
Name=OrionOS
Description=OrionOS Boot Theme
ModuleName=script

[script]
ImageDir=/usr/share/plymouth/themes/orionos
ScriptFile=/usr/share/plymouth/themes/orionos/orionos.script
EOF

    cat > "${pkgdir}/usr/share/plymouth/themes/orionos/orionos.script" << 'EOF'
// OrionOS Plymouth Boot Script
// Creates a smooth, modern boot animation

var logo;
var spinner;
var dots = [];
var progress = 0;
var target_progress = 0;
var boot_time = 0;

function fun_check_progress_callback() {
    return progress;
}

fun dialog_setup() {
    var background = Image.Text("", 0, 0, 0);
    window.SetBackgroundTopColor(0.06, 0.06, 0.14);
    window.SetBackgroundBottomColor(0.06, 0.06, 0.14);

    // Logo - centered
    logo = Image("logo.png");
    if (!logo) {
        logo = Image.Text("OrionOS", 0.00, 0.71, 1.0);
    }

    // Create spinner dots
    for (var i = 0; i < 8; i++) {
        var dot = Image("dot.png");
        if (!dot) {
            dot = Image.Text(".", 0.00, 0.71, 1.0);
        }
        dots[i] = {
            image: dot,
            angle: (i / 8) * Math.PI * 2
        };
    }
}

fun dialog_opacity() {
    return 1.0;
}

fun refresh_callback() {
    boot_time += 1;

    // Smooth progress
    progress += (target_progress - progress) * 0.1;

    // Clear and redraw
    window.Clear();

    var screen_width = Window.GetWidth();
    var screen_height = Window.GetHeight();
    var center_x = screen_width / 2;
    var center_y = screen_height / 2;

    // Draw logo
    if (logo) {
        var logo_x = center_x - logo.GetWidth() / 2;
        var logo_y = center_y - 80;
        logo.Draw(logo_x, logo_y);
    }

    // Draw animated spinner
    var spinner_radius = 30;
    var spinner_y = center_y + 40;
    for (var i = 0; i < 8; i++) {
        var dot = dots[i];
        var angle = dot.angle + (boot_time * 0.05);
        var x = center_x + Math.cos(angle) * spinner_radius - dot.image.GetWidth() / 2;
        var y = spinner_y + Math.sin(angle) * spinner_radius - dot.image.GetHeight() / 2;

        // Fade dots based on position
        var alpha = (Math.sin(angle) + 1) / 2 * 0.8 + 0.2;
        dot.image.SetOpacity(alpha);
        dot.image.Draw(x, y);
    }

    // Progress bar (subtle)
    var bar_width = 200;
    var bar_height = 3;
    var bar_x = center_x - bar_width / 2;
    var bar_y = center_y + 80;

    // Background
    var bar_bg = Image(bar_width, bar_height);
    bar_bg.Draw(bar_x, bar_y);

    // Progress fill
    var fill_width = bar_width * progress;
    if (fill_width > 0) {
        var bar_fill = Image(fill_width, bar_height);
        bar_fill.Draw(bar_x, bar_y);
    }

    return 1;
}

fun message_callback(text) {
    // Can display status messages
}

fun quit_callback() {
    // Cleanup on boot complete
}

fun progress_callback(duration, progress_value) {
    target_progress = progress_value;
}
EOF

    # Create Plymouth logo placeholder generation
    cat > "${pkgdir}/usr/share/plymouth/themes/orionos/generate-assets.sh" << 'EOF'
#!/bin/bash
# Generate Plymouth theme assets
THEME_DIR="/usr/share/plymouth/themes/orionos"

# Generate logo using ImageMagick or create a simple text-based logo
cd "$THEME_DIR"

# If ImageMagick is available, create a nice logo
if command -v convert &>/dev/null; then
    convert -size 200x60 xc:transparent \
        -fill '#00B4D8' -gravity center \
        -font "DejaVu-Sans-Bold" -pointsize 32 \
        -draw "text 0,0 'OrionOS'" \
        logo.png

    # Generate spinner dot
    convert -size 8x8 xc:transparent \
        -fill '#00B4D8' -draw 'circle 4,4 4,1' \
        dot.png
else
    # Create placeholder files
    touch logo.png dot.png
fi
EOF
    chmod +x "${pkgdir}/usr/share/plymouth/themes/orionos/generate-assets.sh"

    # ============================================
    # Default settings schema
    # ============================================
    install -d "${pkgdir}/usr/share/glib-2.0/schemas"
    cat > "${pkgdir}/usr/share/glib-2.0/schemas/90_orionos.gschema.override" << 'EOF'
# OrionOS Default Settings

[org.gnome.desktop.interface]
gtk-theme='OrionOS-Dark'
icon-theme='OrionOS'
cursor-theme='OrionOS-Cursor'
font-name='SF Pro Display 11'
monospace-font-name='SF Mono 10'
document-font-name='SF Pro Display 11'
enable-animations=true
clock-show-seconds=false
color-scheme='prefer-dark'

[org.gnome.desktop.sound]
theme-name='OrionOS'

[org.gnome.desktop.wm.preferences]
theme='OrionOS-Dark'
titlebar-font='SF Pro Display Bold 11'
titlebar-uses-system-font=false
button-layout='close,minimize,maximize:'

[org.gnome.desktop.background]
show-desktop-icons=false

[org.gnome.desktop.privacy]
remember-recent-files=true
remove-old-temp-files=true
remove-old-trash-files=true
old-files-age=30

[org.gnome.desktop.session]
session-name='orionos'
idle-delay=900

[org.gnome.settings-daemon.plugins.power]
sleep-inactive-ac-timeout=1800
sleep-inactive-battery-timeout=900
sleep-inactive-ac-type='suspend'
sleep-inactive-battery-type='suspend'
EOF

    log_info "OrionOS Themes installed"
}
