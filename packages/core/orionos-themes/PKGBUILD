    # ==================================================================
    # Theme index.theme
    # ==================================================================
    cat > "$pkgdir/usr/share/themes/OrionOS-Dark/index.theme" << 'EOF'
[Desktop Entry]
Type=X-GNOME-Metatheme
Name=OrionOS-Dark
Comment=OrionOS dark theme - smooth and modern
Encoding=UTF-8

[X-GNOME-Metatheme]
GtkTheme=OrionOS-Dark
MetacityTheme=OrionOS-Dark
IconTheme=Papirus-Dark
CursorTheme=Bibata-Modern-Ice
CursorSize=24
EOF

    # ==================================================================
    # Kvantum theme
    # ==================================================================
    install -d "$pkgdir/usr/share/Kvantum/OrionOS-Dark"
    cat > "$pkgdir/usr/share/Kvantum/OrionOS-Dark/OrionOS-Dark.kvconfig" << 'EOF'
[%General]
theme=OrionOS-Dark
author=OrionOS
comment=OrionOS dark Kvantum theme

[GeneralColors]
window.color=#1e2030
base.color=#24273a
alt.base.color=#1e2030
text.color=#cad3f5
window.text.color=#cad3f5
button.text.color=#cad3f5
disabled.text.color=#6e738d
tooltip.text.color=#cad3f5
highlight.text.color=#1e2030
link.color=#8aadf4
link.visited.color=#c6a0f6
progress.indicator.color=#8aadf4

[Hacks]
transparent_dolphin_view=true
transparent_ktitle_label=true
transparent_menutitle=true
disable_window_blur=false
EOF

    # ==================================================================
    # GRUB Theme
    # ==================================================================
    cat > "$pkgdir/usr/share/grub/themes/orionos/theme.txt" << 'EOF'
# OrionOS GRUB Theme
desktop-image: "background.png"
desktop-color: "#1e2030"

# Boot menu
+ boot_menu {
    left = 15%
    top = 20%
    width = 70%
    height = 60%
    item_font = "JetBrains Mono Regular 16"
    item_color = "#cad3f5"
    selected_item_font = "JetBrains Mono Bold 16"
    selected_item_color = "#8aadf4"
    selected_item_pixmap_style = "select_*.png"
    item_height = 40
    item_padding = 15
    item_spacing = 8
    icon_width = 32
    icon_height = 32
}

# Progress bar
+ progress_bar {
    id = "__timeout__"
    left = 15%
    top = 85%
    width = 70%
    height = 20
    font = "JetBrains Mono Regular 14"
    fg_color = "#8aadf4"
    bg_color = "#363a4f"
    border_color = "#494d64"
    show_text = true
    text_color = "#cad3f5"
}

# Title
+ label {
    left = 15%
    top = 10%
    width = 70%
    align = "center"
    font = "JetBrains Mono Bold 28"
    color = "#b4befe"
    text = "OrionOS"
}

# Version
+ label {
    left = 15%
    top = 14%
    width = 70%
    align = "center"
    font = "JetBrains Mono Regular 14"
    color = "#6e738d"
    text = "Select OS to boot"
}
EOF

    # GRUB background (will be generated during install)
    cat > "$pkgdir/usr/share/grub/themes/orionos/README" << 'EOF'
OrionOS GRUB Theme
===================

This is the OrionOS bootloader theme. The background.png should be
generated during installation from the wallpaper collection.

Default resolution: 1920x1080
EOF

    # ==================================================================
    # Plymouth Theme
    # ==================================================================
    cat > "$pkgdir/usr/share/plymouth/themes/orionos/orionos.plymouth" << 'EOF'
[Plymouth Theme]
Name=OrionOS
Description=OrionOS boot splash theme
ModuleName=script

[script]
ImageDir=/usr/share/plymouth/themes/orionos
ScriptFile=/usr/share/plymouth/themes/orionos/orionos.script
EOF

    cat > "$pkgdir/usr/share/plymouth/themes/orionos/orionos.script" << 'EOF'
// OrionOS Plymouth Script
// Simple animated boot splash

var logo = Image("logo.png");
var logo_sprite = Sprite(logo);

// Center the logo
logo_sprite.SetX((Window.GetWidth() - logo.GetWidth()) / 2);
logo_sprite.SetY((Window.GetHeight() - logo.GetHeight()) / 2 - 50);

// Progress bar
var progress = 0;
var progress_bar_width = 300;
var progress_bar_height = 4;
var progress_bar_x = (Window.GetWidth() - progress_bar_width) / 2;
var progress_bar_y = Window.GetHeight() / 2 + 80;

function refresh() {
    // Update progress bar
    progress = Math.Min(progress + 0.005, 1);

    // Draw progress bar background
    var bg = Image(progress_bar_width, progress_bar_height);
    bg.Fill(0x363a4f);
    var bg_sprite = Sprite(bg);
    bg_sprite.SetX(progress_bar_x);
    bg_sprite.SetY(progress_bar_y);

    // Draw progress bar fill
    var fill_width = Math.Int(progress_bar_width * progress);
    if (fill_width > 0) {
        var fill = Image(fill_width, progress_bar_height);
        fill.Fill(0x8aadf4);
        var fill_sprite = Sprite(fill);
        fill_sprite.SetX(progress_bar_x);
        fill_sprite.SetY(progress_bar_y);
    }

    // Animate logo (subtle pulse)
    var scale = 1 + 0.02 * Math.Sin(progress * 20);
    logo_sprite.SetOpacity(0.7 + 0.3 * Math.Sin(progress * 10));
}

Plymouth.SetRefreshFunction(refresh);
EOF

    # ==================================================================
    # Default user configuration
    # ==================================================================
    cat > "$pkgdir/etc/skel/.config/gtk-3.0/settings.ini" << 'EOF'
[Settings]
gtk-theme-name=OrionOS-Dark
gtk-icon-theme-name=Papirus-Dark
gtk-font-name=JetBrains Mono 11
gtk-cursor-theme-name=Bibata-Modern-Ice
gtk-cursor-theme-size=24
gtk-toolbar-style=GTK_TOOLBAR_BOTH_HORIZ
gtk-toolbar-icon-size=GTK_ICON_SIZE_LARGE_TOOLBAR
gtk-button-images=0
gtk-menu-images=0
gtk-enable-event-sounds=0
gtk-enable-input-feedback-sounds=0
gtk-xft-antialias=1
gtk-xft-hinting=1
gtk-xft-hintstyle=hintfull
gtk-xft-rgba=rgb
gtk-application-prefer-dark-theme=1
gtk-decoration-layout=icon:minimize,maximize,close
EOF

    cat > "$pkgdir/etc/skel/.config/gtk-4.0/settings.ini" << 'EOF'
[Settings]
gtk-theme-name=OrionOS-Dark
gtk-icon-theme-name=Papirus-Dark
gtk-font-name=JetBrains Mono 11
gtk-cursor-theme-name=Bibata-Modern-Ice
gtk-cursor-theme-size=24
gtk-application-prefer-dark-theme=1
gtk-decoration-layout=icon:minimize,maximize,close
EOF

    cat > "$pkgdir/etc/skel/.config/Kvantum/kvantum.kvconfig" << 'EOF'
[General]
theme=OrionOS-Dark
EOF

    # ==================================================================
    # Documentation
    # ==================================================================
    install -Dm644 /dev/stdin "$pkgdir/usr/share/doc/orionos-themes/README" << 'EOF'
OrionOS Themes
===============

This package provides the OrionOS visual identity:

Themes:
- OrionOS-Dark (GTK3/GTK4): Catppuccin Macchiato-based dark theme
- OrionOS-Dark (Kvantum): Qt application theming
- GRUB theme: Bootloader styling
- Plymouth theme: Boot splash

Default configuration:
- Icon theme: Papirus-Dark
- Cursor: Bibata-Modern-Ice
- Font: JetBrains Mono

Installation:
Themes are automatically applied when the package is installed
alongside orionos-desktop.
EOF
}
