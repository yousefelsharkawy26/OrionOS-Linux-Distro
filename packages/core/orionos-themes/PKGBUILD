# Maintainer: OrionOS Team <team@orionos.org>
pkgname=orionos-themes
pkgver=0.1.0
pkgrel=1
pkgdesc="OrionOS Visual Themes - GTK, Icon, Cursor, and Sound themes"
arch=('any')
url="https://orionos.org"
license=('GPL-3.0')
depends=(
    'gtk3'
    'gtk4'
    'gnome-themes-extra'
)
source=()
sha256sums=()

package() {
    # Theme directories
    install -d "${pkgdir}/usr/share/themes"
    install -d "${pkgdir}/usr/share/icons"
    install -d "${pkgdir}/usr/share/sounds"
    install -d "${pkgdir}/usr/share/plymouth/themes/orionos"
