ORION_LIGHTEST=#F0F0FF

# Semantic Colors
ORION_SUCCESS=#06D6A0
ORION_WARNING=#FFD166
ORION_ERROR=#FF6B6B
ORION_INFO=#00B4D8

# Background Colors
ORION_BG_PRIMARY=#0F0F23
ORION_BG_SECONDARY=#1A1A3E
ORION_BG_TERTIARY=#2A2A4A
ORION_BG_ELEVATED=#252550

# Text Colors
ORION_TEXT_PRIMARY=#F0F0FF
ORION_TEXT_SECONDARY=#A0A0C0
ORION_TEXT_TERTIARY=#6A6A8A
ORION_TEXT_DISABLED=#4A4A6A

# Border Colors
ORION_BORDER_DEFAULT=#2A2A4A
ORION_BORDER_FOCUSED=#00B4D8
ORION_BORDER_ERROR=#FF6B6B

# Gradient Definitions
ORION_GRADIENT_PRIMARY=linear-gradient(135deg, #00B4D8, #7B2FF7)
ORION_GRADIENT_ACCENT=linear-gradient(135deg, #FF6B6B, #F72585)
ORION_GRADIENT_SUCCESS=linear-gradient(135deg, #06D6A0, #00B4D8)
