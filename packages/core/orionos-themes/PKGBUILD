    background: rgba(180, 190, 254, 0.1);
}

popover {
    background: @menu_bg_color;
    border: 1px solid #363a4f;
    border-radius: 12px;
    padding: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
