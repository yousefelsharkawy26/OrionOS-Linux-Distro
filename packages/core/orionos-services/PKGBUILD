#!/usr/bin/env python3
"""
OrionOS Power Management Daemon
Handles battery notifications, power profile switching, and suspend/hibernate.
"""

import os
import sys
import json
import time
import logging
import argparse
import subprocess
from pathlib import Path
from datetime import datetime

LOG_DIR = Path("/var/log/orionos")
LOG_DIR.mkdir(parents=True, exist_ok=True)

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[
        logging.FileHandler(LOG_DIR / "powerd.log"),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger("orionos-powerd")

BATTERY_PATH = Path("/sys/class/power_supply")
CONFIG_FILE = Path("/etc/orionos/power.conf")


def load_config():
    if CONFIG_FILE.exists():
        try:
            with open(CONFIG_FILE) as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            pass
    return {
        "battery_threshold_low": 20,
        "battery_threshold_critical": 10,
        "auto_powersave_on_battery": True,
    }


def get_battery_info():
    """Get battery status information."""
    batteries = []
    for bat in sorted(BATTERY_PATH.glob("BAT*")):
        try:
            with open(bat / "capacity") as f:
                capacity = int(f.read().strip())
            with open(bat / "status") as f:
                status = f.read().strip()
            batteries.append({
                "name": bat.name,
                "capacity": capacity,
                "status": status,
            })
        except (IOError, ValueError):
            pass
    return batteries


def send_notification(summary, body, urgency="normal"):
    try:
        subprocess.run(
            ["dunstify", "-u", urgency, "-a", "OrionOS Power", summary, body],
            capture_output=True
        )
    except FileNotFoundError:
        logger.debug("dunstify not available")


def run_battery_monitor():
    """Monitor battery and send notifications."""
    config = load_config()
    notified_low = False
    notified_critical = False

    logger.info("Battery monitor started")

    while True:
        batteries = get_battery_info()
        for bat in batteries:
            cap = bat["capacity"]
            status = bat["status"]

            if status == "Discharging":
                if cap <= config["battery_threshold_critical"] and not notified_critical:
                    send_notification(
                        "Battery Critical",
                        f"Battery at {cap}%. Plug in charger now!",
                        "critical"
                    )
                    notified_critical = True
                elif cap <= config["battery_threshold_low"] and not notified_low:
                    send_notification(
                        "Battery Low",
                        f"Battery at {cap}%. Consider plugging in.",
                        "normal"
                    )
                    notified_low = True
            else:
                notified_low = False
                notified_critical = False

        time.sleep(60)


def run_powerd():
    """Main power management daemon."""
    config = load_config()
    logger.info("OrionOS Power Daemon started")

    on_battery = False

    while True:
        try:
            batteries = get_battery_info()
            is_discharging = any(b["status"] == "Discharging" for b in batteries)

            if is_discharging != on_battery:
                on_battery = is_discharging
                if on_battery and config.get("auto_powersave_on_battery", True):
                    logger.info("Switched to battery - enabling powersave")
                    subprocess.run(
                        ["orionos-perfd", "--profile", "powersave"],
                        capture_output=True
                    )
                else:
                    logger.info("Switched to AC - restoring default profile")
                    subprocess.run(
                        ["orionos-perfd", "--profile", "default"],
                        capture_output=True
                    )

        except Exception as e:
            logger.error(f"Power daemon error: {e}")

        time.sleep(30)


def main():
    parser = argparse.ArgumentParser(description="OrionOS Power Daemon")
    parser.add_argument("--battery-notify", action="store_true",
                        help="Run battery notification monitor")

    args = parser.parse_args()

    if args.battery_notify:
        run_battery_monitor()
    else:
        run_powerd()


if __name__ == "__main__":
    main()
PYEOF
    chmod 755 "$pkgdir/usr/bin/orionos-powerd"

    # ==================================================================
    # Systemd presets
    # ==================================================================
    install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/system-preset/99-orionos-services.preset" << 'EOF'
enable orionos-perfd.service
enable orionos-updated.service
enable orionos-powerd.service
enable orionos-snapshot.timer
enable orionos-update-check.timer
EOF

    # ==================================================================
    # Documentation
    # ==================================================================
    install -Dm644 /dev/stdin "$pkgdir/usr/share/doc/orionos-services/README" << 'EOF'
OrionOS System Services
========================

This package provides OrionOS core system services:

Services:
- orionos-perfd: Performance profile management (CPU, GPU, I/O)
- orionos-updated: Update management with Btrfs snapshots
- orionos-powerd: Power management and battery monitoring

Features:
- 4 performance profiles: default, performance, powersave, gaming
- Auto-detection of workload (gaming, heavy compute, battery)
- A/B update system with Btrfs snapshots
- Automatic rollback support
- Battery notifications
- Power profile switching on AC/battery transition

Configuration:
- /etc/orionos/performance.conf
- /etc/orionos/update.conf
- /etc/orionos/snapshots.conf
- /etc/orionos/power.conf
EOF
}
