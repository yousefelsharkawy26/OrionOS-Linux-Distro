    # ==================================================================
    cat > "$pkgdir/usr/bin/orionos-perfd" << 'PYEOF'
#!/usr/bin/env python3
"""
OrionOS Performance Daemon
Manages CPU governor, GPU performance, I/O scheduler, and gaming optimizations.
"""

import os
import sys
import json
import time
import signal
import logging
import argparse
import subprocess
from pathlib import Path
from dataclasses import dataclass
from typing import Optional, Dict, List

# Configuration paths
CONFIG_DIR = Path("/etc/orionos")
STATE_DIR = Path("/var/lib/orionos")
LOG_DIR = Path("/var/log/orionos")

# Setup logging
LOG_DIR.mkdir(parents=True, exist_ok=True)
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[
        logging.FileHandler(LOG_DIR / "perfd.log"),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger("orionos-perfd")


@dataclass
class PerformanceProfile:
    name: str
    cpu_governor: str
    energy_preference: str
    io_scheduler: str
    vm_vfs_cache_pressure: int
    vm_swappiness: int
    gpu_power_profile: Optional[str]
    ananicy_rules: List[str]
    gamemode_enabled: bool
    irqbalance: bool
    thermald: bool


PROFILES: Dict[str, PerformanceProfile] = {
    "default": PerformanceProfile(
        name="default",
        cpu_governor="schedutil",
        energy_preference="balance_power",
        io_scheduler="mq-deadline",
        vm_vfs_cache_pressure=50,
        vm_swappiness=10,
        gpu_power_profile=None,
        ananicy_rules=["LowLatency_RT"],
        gamemode_enabled=False,
        irqbalance=True,
        thermald=True,
    ),
    "performance": PerformanceProfile(
        name="performance",
        cpu_governor="performance",
        energy_preference="performance",
        io_scheduler="kyber",
        vm_vfs_cache_pressure=10,
        vm_swappiness=5,
        gpu_power_profile="high",
        ananicy_rules=["LowLatency_RT", "CPU_Bound", "GPU_Bound"],
        gamemode_enabled=True,
        irqbalance=True,
        thermald=False,
    ),
    "powersave": PerformanceProfile(
        name="powersave",
        cpu_governor="powersave",
        energy_preference="power",
        io_scheduler="mq-deadline",
        vm_vfs_cache_pressure=100,
        vm_swappiness=30,
        gpu_power_profile="low",
        ananicy_rules=["Idle"],
        gamemode_enabled=False,
        irqbalance=False,
        thermald=True,
    ),
    "gaming": PerformanceProfile(
        name="gaming",
        cpu_governor="performance",
        energy_preference="performance",
        io_scheduler="kyber",
        vm_vfs_cache_pressure=1,
        vm_swappiness=1,
        gpu_power_profile="high",
        ananicy_rules=["LowLatency_RT", "CPU_Bound", "GPU_Bound", "Audio", "Video"],
        gamemode_enabled=True,
        irqbalance=True,
        thermald=False,
    ),
}


class PerformanceDaemon:
    def __init__(self):
        self.running = True
        self.current_profile = "default"
        self.config_file = CONFIG_DIR / "performance.conf"
        self.state_file = STATE_DIR / "performance.state"
        self._load_config()
        signal.signal(signal.SIGTERM, self._handle_signal)
        signal.signal(signal.SIGHUP, self._handle_reload)

    def _handle_signal(self, signum, frame):
        logger.info("Received shutdown signal")
        self.running = False

    def _handle_reload(self, signum, frame):
        logger.info("Received reload signal")
        self._load_config()

    def _load_config(self):
        if self.config_file.exists():
            try:
                with open(self.config_file) as f:
                    config = json.load(f)
                self.current_profile = config.get("profile", "default")
                logger.info(f"Loaded profile: {self.current_profile}")
            except (json.JSONDecodeError, IOError) as e:
                logger.warning(f"Could not load config: {e}")
                self.current_profile = "default"

    def _save_state(self):
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        with open(self.state_file, 'w') as f:
            json.dump({
                "profile": self.current_profile,
                "timestamp": time.time(),
            }, f)

    def _set_cpu_governor(self, governor: str) -> bool:
        try:
            cpus = [p for p in Path("/sys/devices/system/cpu").glob("cpu*/cpufreq/scaling_governor")]
            for cpu in cpus:
                with open(cpu, 'w') as f:
                    f.write(governor)
            logger.info(f"CPU governor set to: {governor}")
            return True
        except IOError as e:
            logger.error(f"Failed to set CPU governor: {e}")
            return False

    def _set_energy_preference(self, preference: str) -> bool:
        try:
            prefs = [p for p in Path("/sys/devices/system/cpu").glob("cpu*/cpufreq/energy_performance_preference")]
            for pref_file in prefs:
                with open(pref_file, 'w') as f:
                    f.write(preference)
            logger.info(f"Energy preference set to: {preference}")
            return True
        except IOError:
            logger.debug("Energy preference not available")
            return False

    def _set_io_scheduler(self, scheduler: str) -> bool:
        try:
            devices = []
            for queue in Path("/sys/block").glob("*/queue/scheduler"):
                with open(queue) as f:
                    schedulers = f.read()
                if scheduler in schedulers:
                    with open(queue, 'w') as f:
                        f.write(scheduler)
                    devices.append(queue.parent.name)
            if devices:
                logger.info(f"I/O scheduler set to {scheduler} on: {', '.join(devices)}")
            return True
        except IOError as e:
            logger.error(f"Failed to set I/O scheduler: {e}")
            return False

    def _set_vm_params(self, cache_pressure: int, swappiness: int) -> bool:
        try:
            with open("/proc/sys/vm/vfs_cache_pressure", 'w') as f:
                f.write(str(cache_pressure))
            with open("/proc/sys/vm/swappiness", 'w') as f:
                f.write(str(swappiness))
            logger.info(f"VM: vfs_cache_pressure={cache_pressure}, swappiness={swappiness}")
            return True
        except IOError as e:
            logger.error(f"Failed to set VM parameters: {e}")
            return False

    def _set_gpu_profile(self, profile: Optional[str]) -> bool:
        if not profile:
            return True
        try:
            # Check for AMD GPU
            amd_pp = Path("/sys/class/drm/card0/device/pp_dpm_sclk")
            if amd_pp.exists():
                mode = "0" if profile == "low" else "1" if profile == "auto" else "7"
                with open(amd_pp, 'w') as f:
                    f.write(mode)
                logger.info(f"AMD GPU profile set to: {profile}")
                return True

            # Check for NVIDIA
            nvidia_smi = subprocess.run(
                ["nvidia-smi", "-q", "-d", "PERFORMANCE"],
                capture_output=True, text=True
            )
            if nvidia_smi.returncode == 0:
                nvidia_mode = "0" if profile == "low" else "1" if profile == "auto" else "4"
                subprocess.run(
                    ["nvidia-smi", "-pm", "1"],
                    capture_output=True
                )
                subprocess.run(
                    ["nvidia-smi", "-pl", nvidia_mode],
                    capture_output=True
                )
                logger.info(f"NVIDIA GPU profile set to: {profile}")
                return True

            logger.debug("No discrete GPU profile control available")
            return True
        except Exception as e:
            logger.error(f"Failed to set GPU profile: {e}")
            return False

    def _set_gamemode(self, enabled: bool) -> bool:
        try:
            if enabled:
                subprocess.run(["systemctl", "start", "gamemoded"], capture_output=True)
                logger.info("GameMode enabled")
            else:
                subprocess.run(["systemctl", "stop", "gamemoded"], capture_output=True)
                logger.info("GameMode disabled")
            return True
        except Exception as e:
            logger.error(f"Failed to set gamemode: {e}")
            return False

    def _set_irqbalance(self, enabled: bool) -> bool:
        try:
            action = "start" if enabled else "stop"
            subprocess.run(["systemctl", action, "irqbalance"], capture_output=True)
            logger.info(f"IRQBalance {'enabled' if enabled else 'disabled'}")
            return True
        except Exception as e:
            logger.error(f"Failed to set irqbalance: {e}")
            return False

    def _set_thermald(self, enabled: bool) -> bool:
        try:
            action = "start" if enabled else "stop"
            subprocess.run(["systemctl", action, "thermald"], capture_output=True)
            logger.info(f"Thermald {'enabled' if enabled else 'disabled'}")
            return True
        except Exception as e:
            logger.error(f"Failed to set thermald: {e}")
            return False

    def apply_profile(self, profile_name: str) -> bool:
        if profile_name not in PROFILES:
            logger.error(f"Unknown profile: {profile_name}")
            return False

        profile = PROFILES[profile_name]
        logger.info(f"Applying performance profile: {profile_name}")

        results = []
        results.append(self._set_cpu_governor(profile.cpu_governor))
        results.append(self._set_energy_preference(profile.energy_preference))
        results.append(self._set_io_scheduler(profile.io_scheduler))
        results.append(self._set_vm_params(profile.vm_vfs_cache_pressure, profile.vm_swappiness))
        results.append(self._set_gpu_profile(profile.gpu_power_profile))
        results.append(self._set_gamemode(profile.gamemode_enabled))
        results.append(self._set_irqbalance(profile.irqbalance))
        results.append(self._set_thermald(profile.thermald))

        self.current_profile = profile_name
        self._save_state()

        if all(results):
            logger.info(f"Profile '{profile_name}' applied successfully")
            return True
        else:
            logger.warning(f"Profile '{profile_name}' applied with some failures")
            return False

    def detect_workload(self) -> str:
        """Auto-detect current workload and suggest profile."""
        try:
            # Check for gaming processes
            gaming_procs = [
                "steam", "gamescope", "gamemoderun",
                "osu!", "cs2", "dota2", "rocketleague",
            ]
            ps_output = subprocess.run(
                ["ps", "-eo", "comm"],
                capture_output=True, text=True
            ).stdout
            for proc in gaming_procs:
                if proc.lower() in ps_output.lower():
                    return "gaming"

            # Check CPU load
            with open("/proc/loadavg") as f:
                load = float(f.read().split()[0])
            cpu_count = os.cpu_count() or 4
            if load / cpu_count > 0.7:
                return "performance"

            # Check if on battery
            power_supply = Path("/sys/class/power_supply")
            for ps in power_supply.glob("BAT*"):
                status_file = ps / "status"
                if status_file.exists():
                    with open(status_file) as f:
                        if f.read().strip() == "Discharging":
                            return "powersave"

            return "default"
        except Exception as e:
            logger.error(f"Workload detection failed: {e}")
            return "default"

    def run(self):
        logger.info("OrionOS Performance Daemon started")
        self.apply_profile(self.current_profile)

        while self.running:
            # Check for auto-detection
            if self.config_file.exists():
                try:
                    with open(self.config_file) as f:
                        config = json.load(f)
                    if config.get("auto_detect", False):
                        detected = self.detect_workload()
                        if detected != self.current_profile:
                            self.apply_profile(detected)
                except Exception as e:
                    logger.error(f"Auto-detection error: {e}")

            time.sleep(30)

        logger.info("OrionOS Performance Daemon stopped")


def main():
    parser = argparse.ArgumentParser(description="OrionOS Performance Daemon")
    parser.add_argument("--profile", "-p", choices=list(PROFILES.keys()),
                        help="Apply a performance profile")
    parser.add_argument("--list", "-l", action="store_true",
                        help="List available profiles")
    parser.add_argument("--status", "-s", action="store_true",
                        help="Show current status")
    parser.add_argument("--daemon", "-d", action="store_true",
                        help="Run as daemon")
    parser.add_argument("--auto", "-a", action="store_true",
                        help="Enable auto-detection")

    args = parser.parse_args()

    if args.list:
        print("Available profiles:")
        for name, profile in PROFILES.items():
            print(f"  {name:12s} - CPU: {profile.cpu_governor}, I/O: {profile.io_scheduler}")
        sys.exit(0)

    if args.status:
        state_file = STATE_DIR / "performance.state"
        if state_file.exists():
            with open(state_file) as f:
                state = json.load(f)
            print(f"Current profile: {state.get('profile', 'default')}")
            print(f"Last updated: {state.get('timestamp', 'unknown')}")
        else:
            print("Current profile: default (not configured)")
        sys.exit(0)

    if args.profile:
        daemon = PerformanceDaemon()
        success = daemon.apply_profile(args.profile)
        if args.auto:
            CONFIG_DIR.mkdir(parents=True, exist_ok=True)
            with open(CONFIG_DIR / "performance.conf", 'w') as f:
                json.dump({"profile": args.profile, "auto_detect": True}, f)
        sys.exit(0 if success else 1)

    if args.daemon:
        daemon = PerformanceDaemon()
        daemon.run()
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
PYEOF
    chmod 755 "$pkgdir/usr/bin/orionos-perfd"

    # ==================================================================
    # Update Daemon
    # ==================================================================
    cat > "$pkgdir/usr/bin/orionos-updated" << 'PYEOF'
#!/usr/bin/env python3
"""
OrionOS Update Daemon
Manages system updates with A/B Btrfs snapshot support.
"""

import os
import sys
import json
import time
import shutil
import signal
import logging
import argparse
import subprocess
import hashlib
from pathlib import Path
from datetime import datetime
from dataclasses import dataclass
from typing import Optional, List, Dict

# Configuration paths
CONFIG_DIR = Path("/etc/orionos")
STATE_DIR = Path("/var/lib/orionos")
CACHE_DIR = Path("/var/cache/orionos")
LOG_DIR = Path("/var/log/orionos")

# Setup logging
LOG_DIR.mkdir(parents=True, exist_ok=True)
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[
        logging.FileHandler(LOG_DIR / "updated.log"),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger("orionos-updated")

# Btrfs subvolumes
SNAPSHOT_DIR = Path("/.snapshots")
ROOT_SUBVOL = "@"
SNAPSHOT_PREFIX = "pre-update"


@dataclass
class UpdateConfig:
    auto_check: bool = True
    auto_apply: bool = False
    check_interval_hours: int = 6
    snapshot_before_update: bool = True
    keep_snapshots: int = 5
    mirrors: List[str] = None
    ignore_packages: List[str] = None

    def __post_init__(self):
        if self.mirrors is None:
            self.mirrors = []
        if self.ignore_packages is None:
            self.ignore_packages = []


class SnapshotManager:
    """Manages Btrfs snapshots for system recovery."""

    @staticmethod
    def create_snapshot(name: Optional[str] = None) -> Optional[str]:
        if not name:
            name = f"{SNAPSHOT_PREFIX}-{datetime.now().strftime('%Y%m%d-%H%M%S')}"

        snapshot_path = SNAPSHOT_DIR / name

        try:
            # Ensure snapshot directory exists
            SNAPSHOT_DIR.mkdir(parents=True, exist_ok=True)

            # Create read-only snapshot of root
            result = subprocess.run(
                ["btrfs", "subvolume", "snapshot", "/", str(snapshot_path)],
                capture_output=True, text=True
            )
            if result.returncode == 0:
                logger.info(f"Created snapshot: {name}")
                return name
            else:
                logger.error(f"Snapshot failed: {result.stderr}")
                return None
        except Exception as e:
            logger.error(f"Snapshot creation error: {e}")
            return None

    @staticmethod
    def list_snapshots() -> List[Dict]:
        snapshots = []
        if not SNAPSHOT_DIR.exists():
            return snapshots

        for snapshot in sorted(SNAPSHOT_DIR.iterdir()):
            if snapshot.is_dir() and not snapshot.is_symlink():
                try:
                    info = subprocess.run(
                        ["btrfs", "subvolume", "show", str(snapshot)],
                        capture_output=True, text=True
                    )
                    snapshots.append({
                        "name": snapshot.name,
                        "path": str(snapshot),
                        "created": snapshot.stat().st_ctime,
                    })
                except Exception:
                    pass
        return snapshots

    @staticmethod
    def delete_snapshot(name: str) -> bool:
        snapshot_path = SNAPSHOT_DIR / name
        try:
            result = subprocess.run(
                ["btrfs", "subvolume", "delete", str(snapshot_path)],
                capture_output=True, text=True
            )
            if result.returncode == 0:
                logger.info(f"Deleted snapshot: {name}")
                return True
            else:
                logger.error(f"Snapshot deletion failed: {result.stderr}")
                return False
        except Exception as e:
            logger.error(f"Snapshot deletion error: {e}")
            return False

    @staticmethod
    def rollback_to(name: str) -> bool:
        snapshot_path = SNAPSHOT_DIR / name
        if not snapshot_path.exists():
            logger.error(f"Snapshot not found: {name}")
            return False

        try:
            # This requires booting from snapshot via GRUB
            # Mark snapshot as boot target
            boot_marker = Path("/.snapshot-boot-target")
            with open(boot_marker, 'w') as f:
                f.write(str(snapshot_path))

            logger.info(f"Marked snapshot for rollback: {name}")
            logger.info("Reboot to complete rollback")
            return True
        except Exception as e:
            logger.error(f"Rollback preparation failed: {e}")
            return False

    @staticmethod
    def cleanup_old_snapshots(keep: int = 5):
        snapshots = SnapshotManager.list_snapshots()
        if len(snapshots) <= keep:
            return

        # Sort by creation time (oldest first)
        snapshots.sort(key=lambda x: x["created"])

        # Delete oldest snapshots
        for snapshot in snapshots[:-keep]:
            SnapshotManager.delete_snapshot(snapshot["name"])


class UpdateManager:
    """Manages system updates with safety features."""

    def __init__(self):
        self.config = self._load_config()
        self.state_file = STATE_DIR / "update.state"
        STATE_DIR.mkdir(parents=True, exist_ok=True)

    def _load_config(self) -> UpdateConfig:
        config_file = CONFIG_DIR / "update.conf"
        if config_file.exists():
            try:
                with open(config_file) as f:
                    data = json.load(f)
                return UpdateConfig(**data)
            except (json.JSONDecodeError, TypeError) as e:
                logger.warning(f"Invalid config: {e}")
        return UpdateConfig()

    def check_updates(self) -> Dict:
        """Check for available updates."""
        try:
            # Refresh package databases
            subprocess.run(
                ["pacman", "-Sy"],
                capture_output=True
            )

            # Check for updates
            result = subprocess.run(
                ["pacman", "-Qu"],
                capture_output=True, text=True
            )

            updates = []
            if result.stdout:
                for line in result.stdout.strip().split('\n'):
                    if line:
                        parts = line.split()
                        if len(parts) >= 4:
                            updates.append({
                                "package": parts[0],
                                "current": parts[1],
                                "new": parts[3],
                            })

            return {
                "has_updates": len(updates) > 0,
                "count": len(updates),
                "packages": updates,
                "timestamp": datetime.now().isoformat(),
            }
        except Exception as e:
            logger.error(f"Update check failed: {e}")
            return {
                "has_updates": False,
                "count": 0,
                "packages": [],
                "error": str(e),
            }

    def apply_updates(self, force: bool = False) -> bool:
        """Apply updates with snapshot protection."""
        if not force and not self.config.auto_apply:
            logger.info("Auto-apply disabled, skipping")
            return False

        # Create pre-update snapshot
        if self.config.snapshot_before_update:
            snapshot_name = SnapshotManager.create_snapshot()
            if not snapshot_name:
                logger.error("Failed to create snapshot, aborting update")
                return False

        try:
            # Sync package databases
            subprocess.run(["pacman", "-Syu", "--noconfirm"], check=True)

            # Cleanup old snapshots
            SnapshotManager.cleanup_old_snapshots(self.config.keep_snapshots)

            logger.info("Updates applied successfully")
            return True
        except subprocess.CalledProcessError as e:
            logger.error(f"Update failed: {e}")
            return False

    def update_aur_packages(self) -> bool:
        """Update AUR packages using paru."""
        try:
            result = subprocess.run(
                ["paru", "-Sua", "--noconfirm"],
                capture_output=True, text=True
            )
            if result.returncode == 0:
                logger.info("AUR packages updated")
                return True
            else:
                logger.warning(f"AUR update issues: {result.stderr}")
                return False
        except FileNotFoundError:
            logger.debug("paru not installed, skipping AUR updates")
            return True

    def update_flatpak(self) -> bool:
        """Update Flatpak packages."""
        try:
            result = subprocess.run(
                ["flatpak", "update", "-y"],
                capture_output=True, text=True
            )
            if result.returncode == 0:
                logger.info("Flatpak packages updated")
                return True
            else:
                logger.warning(f"Flatpak update issues: {result.stderr}")
                return False
        except FileNotFoundError:
            logger.debug("Flatpak not installed, skipping")
            return True

    def run(self):
        """Main daemon loop."""
        logger.info("OrionOS Update Daemon started")

        while True:
            try:
                # Check for updates
                status = self.check_updates()
                logger.info(f"Update check: {status['count']} packages available")

                # Save state
                with open(self.state_file, 'w') as f:
                    json.dump(status, f)

                # Auto-apply if enabled
                if status["has_updates"] and self.config.auto_apply:
                    self.apply_updates()
                    self.update_aur_packages()
                    self.update_flatpak()

            except Exception as e:
                logger.error(f"Daemon error: {e}")

            # Sleep until next check
            time.sleep(self.config.check_interval_hours * 3600)


def main():
    parser = argparse.ArgumentParser(description="OrionOS Update Manager")
    parser.add_argument("--check", "-c", action="store_true",
                        help="Check for updates")
    parser.add_argument("--apply", "-a", action="store_true",
                        help="Apply updates")
    parser.add_argument("--snapshot", "-s", action="store_true",
                        help="Create snapshot")
    parser.add_argument("--rollback", "-r", metavar="SNAPSHOT",
                        help="Rollback to snapshot")
    parser.add_argument("--list-snapshots", "-l", action="store_true",
                        help="List snapshots")
    parser.add_argument("--cleanup", action="store_true",
                        help="Cleanup old snapshots")
    parser.add_argument("--daemon", "-d", action="store_true",
                        help="Run as daemon")
    parser.add_argument("--force", "-f", action="store_true",
                        help="Force operation")

    args = parser.parse_args()

    manager = UpdateManager()

    if args.check:
        status = manager.check_updates()
        print(json.dumps(status, indent=2))
        sys.exit(0 if status["has_updates"] else 0)

    if args.apply:
        success = manager.apply_updates(force=args.force)
        sys.exit(0 if success else 1)

    if args.snapshot:
        name = SnapshotManager.create_snapshot()
        sys.exit(0 if name else 1)

    if args.rollback:
        success = SnapshotManager.rollback_to(args.rollback)
        sys.exit(0 if success else 1)

    if args.list_snapshots:
        snapshots = SnapshotManager.list_snapshots()
        for snap in snapshots:
            created = datetime.fromtimestamp(snap["created"]).strftime("%Y-%m-%d %H:%M:%S")
            print(f"{snap['name']:40s} {created}")
        sys.exit(0)

    if args.cleanup:
        SnapshotManager.cleanup_old_snapshots()
        sys.exit(0)

    if args.daemon:
        manager.run()
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
PYEOF
    chmod 755 "$pkgdir/usr/bin/orionos-updated"

