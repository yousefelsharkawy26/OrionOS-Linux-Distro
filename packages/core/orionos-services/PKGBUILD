[Unit]
Description=OrionOS Performance Optimization Service
After=multi-user.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/share/orionos/services/performance-service start
ExecStop=/usr/share/orionos/services/performance-service stop

[Install]
WantedBy=multi-user.target
EOF

    cat > "${pkgdir}/usr/share/orionos/services/performance-service" << 'EOF'
#!/usr/bin/env python3
"""
OrionOS Performance Service
Automatically optimizes system performance based on workload
"""

import os
import sys
import psutil
import time
import subprocess
from pathlib import Path

class PerformanceService:
    def __init__(self):
        self.config_path = Path("/etc/orionos/services/performance.conf")
        self.state_path = Path("/run/orionos/performance.state")
        self.load_threshold_high = 70.0
        self.load_threshold_low = 30.0

    def read_config(self):
        """Read performance configuration"""
        config = {
            'auto_performance': True,
            'game_mode': False,
            'power_profile': 'balanced',
        }
        if self.config_path.exists():
            with open(self.config_path) as f:
                for line in f:
                    line = line.strip()
                    if line and not line.startswith('#'):
                        key, value = line.split('=', 1)
                        config[key.strip()] = value.strip()
        return config

    def set_cpu_governor(self, governor):
        """Set CPU frequency governor"""
        cpu_paths = Path("/sys/devices/system/cpu").glob("cpu*/cpufreq/scaling_governor")
        for path in cpu_paths:
            try:
                with open(path, 'w') as f:
                    f.write(governor)
            except PermissionError:
                pass

    def set_io_scheduler(self, scheduler):
        """Set I/O scheduler for all block devices"""
        for device in Path("/sys/block").glob("*"):
            scheduler_path = device / "queue/scheduler"
            if scheduler_path.exists():
                try:
                    with open(scheduler_path, 'w') as f:
                        f.write(scheduler)
                except PermissionError:
                    pass

    def set_vm_settings(self, profile):
        """Set VM settings based on profile"""
        settings = {
            'performance': {
                'swappiness': 10,
                'vfs_cache_pressure': 50,
                'dirty_ratio': 15,
            },
            'balanced': {
                'swappiness': 30,
                'vfs_cache_pressure': 100,
                'dirty_ratio': 20,
            },
            'powersave': {
                'swappiness': 60,
                'vfs_cache_pressure': 150,
                'dirty_ratio': 10,
            }
        }
        if profile in settings:
            for key, value in settings[profile].items():
                path = f"/proc/sys/vm/{key}"
                try:
                    with open(path, 'w') as f:
                        f.write(str(value))
                except PermissionError:
                    pass

    def detect_gaming_mode(self):
        """Detect if gaming mode should be active"""
        gaming_processes = [
            'steam', 'steamwebhelper', 'gamescope', 'mangohud',
            'wine', 'wine64', 'wineserver', 'proton',
            'osu!', 'factorio', 'minecraft', 'javaw',
            'Overwatch', 'League of', 'Valorant',
        ]
        for proc in psutil.process_iter(['name', 'cmdline']):
            try:
                name = proc.info['name'] or ''
                cmdline = ' '.join(proc.info['cmdline'] or [])
                for game in gaming_processes:
                    if game.lower() in name.lower() or game.lower() in cmdline.lower():
                        return True
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
        return False

    def optimize_for_gaming(self):
        """Apply gaming-specific optimizations"""
        # CPU governor to performance
        self.set_cpu_governor('performance')

        # I/O scheduler to mq-deadline for better latency
        self.set_io_scheduler('mq-deadline')

        # Disable NMI watchdog
        try:
            with open('/proc/sys/kernel/nmi_watchdog', 'w') as f:
                f.write('0')
        except PermissionError:
            pass

        # Disable transparent hugepage defragmentation
        try:
            with open('/sys/kernel/mm/transparent_hugepage/defrag', 'w') as f:
                f.write('never')
        except PermissionError:
            pass

        # Set process priorities for common games
        for proc in psutil.process_iter(['pid', 'name']):
            try:
                name = proc.info['name'] or ''
                if any(g in name.lower() for g in ['steam', 'gamescope', 'wine', 'proton']):
                    os.nice(-5)
                    # Set CPU affinity to performance cores if available
                    p = psutil.Process(proc.info['pid'])
                    cpu_count = psutil.cpu_count()
                    if cpu_count > 4:
                        p.cpu_affinity(list(range(cpu_count // 2, cpu_count)))
            except (psutil.NoSuchProcess, psutil.AccessDenied, PermissionError):
                continue

    def apply_profile(self, profile):
        """Apply performance profile"""
        print(f"[OrionOS] Applying performance profile: {profile}")

        if profile == 'performance':
            self.set_cpu_governor('performance')
            self.set_io_scheduler('kyber')
            self.set_vm_settings('performance')
        elif profile == 'powersave':
            self.set_cpu_governor('powersave')
            self.set_io_scheduler('bfq')
            self.set_vm_settings('powersave')
        elif profile == 'gaming':
            self.optimize_for_gaming()
        else:  # balanced
            self.set_cpu_governor('schedutil')
            self.set_io_scheduler('mq-deadline')
            self.set_vm_settings('balanced')

        # Save state
        self.state_path.write_text(profile)

    def run(self):
        """Main service loop"""
        config = self.read_config()

        if not config.get('auto_performance', 'True') == 'True':
            print("[OrionOS] Auto-performance disabled")
            return

        # Apply initial profile
        self.apply_profile('balanced')

        # Monitor loop
        while True:
            try:
                config = self.read_config()

                if config.get('game_mode') == 'True' or self.detect_gaming_mode():
                    self.apply_profile('gaming')
                elif config.get('power_profile') == 'performance':
                    self.apply_profile('performance')
                elif config.get('power_profile') == 'powersave':
                    self.apply_profile('powersave')
                else:
                    # Auto-detect based on load
                    load = psutil.cpu_percent(interval=1)
                    if load > self.load_threshold_high:
                        self.apply_profile('performance')
                    elif load < self.load_threshold_low:
                        current = self.state_path.read_text().strip() if self.state_path.exists() else ''
                        if current == 'performance':
                            self.apply_profile('balanced')

                time.sleep(10)
            except KeyboardInterrupt:
                break
            except Exception as e:
                print(f"[OrionOS] Error: {e}")
                time.sleep(30)

def main():
    service = PerformanceService()

    if len(sys.argv) < 2:
        print("Usage: performance-service {start|stop|status}")
        sys.exit(1)

    cmd = sys.argv[1]
    if cmd == 'start':
        print("[OrionOS] Starting performance service...")
        service.run()
    elif cmd == 'stop':
        print("[OrionOS] Stopping performance service...")
        service.apply_profile('balanced')
    elif cmd == 'status':
        state = service.state_path.read_text().strip() if service.state_path.exists() else 'unknown'
        print(f"[OrionOS] Current profile: {state}")
        print(f"[OrionOS] CPU: {psutil.cpu_percent()}%")
        print(f"[OrionOS] RAM: {psutil.virtual_memory().percent}%")
    else:
        print(f"Unknown command: {cmd}")

if __name__ == '__main__':
    main()
EOF
    chmod +x "${pkgdir}/usr/share/orionos/services/performance-service"

    # ============================================
    # OrionOS Update Service
    # ============================================
