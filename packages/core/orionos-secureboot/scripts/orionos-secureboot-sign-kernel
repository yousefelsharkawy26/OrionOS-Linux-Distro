#!/bin/bash
# OrionOS Secure Boot Kernel Signing
set -euo pipefail

KEY_DIR="/var/lib/orionos/secureboot/keys"
LOG_FILE="/var/log/orionos/secureboot-sign.log"

log_info() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] INFO: $*"; }
log_error() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: $*"; }

if [[ $EUID -ne 0 ]]; then
    log_error "Must be run as root"
    exit 1
fi

sign_kernel() {
    local kernel="$1"
    if [[ ! -f "$kernel" ]]; then
        log_error "Kernel not found: $kernel"
        return 1
    fi

    log_info "Signing: $kernel"
    sbsign --key "$KEY_DIR/db/db.key" \
           --cert "$KEY_DIR/db/db.crt" \
           --output "${kernel}.signed" \
           "$kernel"
    mv "${kernel}.signed" "$kernel"
    log_info "Signed: $kernel"
}

if [[ $# -eq 0 ]]; then
    log_info "Signing all installed kernels..."
    for kernel in /boot/vmlinuz-linux*; do
        if [[ -f "$kernel" ]]; then
            sign_kernel "$kernel"
        fi
    done
else
    for kernel in "$@"; do
        sign_kernel "$kernel"
    done
fi

log_info "Kernel signing complete"
