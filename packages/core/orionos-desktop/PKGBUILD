package() {
    # Desktop configuration files
    install -d "${pkgdir}/etc/orionos/desktop"
    install -d "${pkgdir}/etc/skel/.config"

    # Install Hyprland configuration
    install -d "${pkgdir}/etc/skel/.config/hypr"
    cat > "${pkgdir}/etc/skel/.config/hypr/hyprland.conf" << 'EOF'
# OrionOS Hyprland Configuration
# Auto-generated by OrionOS Desktop installer

# Monitor configuration (auto-detect)
monitor=,preferred,auto,auto
monitor=,addreserved,0,0,40,0

# Input configuration
