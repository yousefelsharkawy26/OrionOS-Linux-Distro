    # Install scripts
    install -d "${pkgdir}/usr/share/orionos/scripts"

    # Dynamic wallpaper script
    cat > "${pkgdir}/usr/share/orionos/scripts/dynamic-wallpaper.sh" << 'EOF'
#!/bin/bash
# OrionOS Dynamic Wallpaper
# Changes wallpaper based on time of day

WALLPAPER_DIR="/usr/share/backgrounds/orionos/dynamic"
HOUR=$(date +%H)

if [[ $HOUR -ge 6 && $HOUR -lt 12 ]]; then
    # Morning
    swww img "${WALLPAPER_DIR}/morning.jpg" --transition-type fade --transition-duration 2
elif [[ $HOUR -ge 12 && $HOUR -lt 17 ]]; then
    # Afternoon
    swww img "${WALLPAPER_DIR}/afternoon.jpg" --transition-type fade --transition-duration 2
elif [[ $HOUR -ge 17 && $HOUR -lt 20 ]]; then
    # Evening
    swww img "${WALLPAPER_DIR}/evening.jpg" --transition-type fade --transition-duration 2
else
    # Night
    swww img "${WALLPAPER_DIR}/night.jpg" --transition-type fade --transition-duration 2
fi
EOF
    chmod +x "${pkgdir}/usr/share/orionos/scripts/dynamic-wallpaper.sh"

    # Night mode script
    cat > "${pkgdir}/usr/share/orionos/scripts/night-mode.sh" << 'EOF'
#!/bin/bash
# OrionOS Night Mode
# Automatic blue light filter

HYPRGAM="${XDG_RUNTIME_DIR}/hypr/${HYPRLAND_INSTANCE_SIGNATURE}/.socket.sock"

NIGHT_TEMP=3500
DAY_TEMP=6500

HOUR=$(date +%H)

if [[ $HOUR -ge 21 || $HOUR -lt 6 ]]; then
    hyprctl --socket "$HYPRGAM" keyword decoration:screen_shader ""
    hyprctl --socket "$HYPRGAM" keyword decoration:rounding 12
else
    hyprctl --socket "$HYPRGAM" keyword decoration:rounding 12
fi
EOF
    chmod +x "${pkgdir}/usr/share/orionos/scripts/night-mode.sh"

    # Performance mode script
    cat > "${pkgdir}/usr/share/orionos/scripts/performance-mode.sh" << 'EOF'
#!/bin/bash
# OrionOS Performance Mode Switcher

MODE="${1:-auto}"

set_performance() {
    # CPU governor
    echo performance | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor
    # GPU performance
    if [[ -f /sys/class/drm/card0/device/power_dpm_force_performance_level ]]; then
        echo high | tee /sys/class/drm/card0/device/power_dpm_force_performance_level
    fi
    # Disable NMI watchdog
    echo 0 > /proc/sys/kernel/nmi_watchdog
    # VM settings
    echo 10 > /proc/sys/vm/swappiness
    echo 50 > /proc/sys/vm/vfs_cache_pressure
    echo 100 > /proc/sys/vm/dirty_ratio
    echo 50 > /proc/sys/vm/dirty_background_ratio
    notify-send "Performance Mode" "Switched to performance mode" -i emblem-system
}

set_powersave() {
    # CPU governor
    echo powersave | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor
    # GPU powersave
    if [[ -f /sys/class/drm/card0/device/power_dpm_force_performance_level ]]; then
        echo low | tee /sys/class/drm/card0/device/power_dpm_force_performance_level
    fi
    # Enable NMI watchdog
    echo 1 > /proc/sys/kernel/nmi_watchdog
    # VM settings
    echo 60 > /proc/sys/vm/swappiness
    echo 100 > /proc/sys/vm/vfs_cache_pressure
    echo 15 > /proc/sys/vm/dirty_ratio
    echo 5 > /proc/sys/vm/dirty_background_ratio
    notify-send "Power Save Mode" "Switched to power save mode" -i emblem-system
}

case "$MODE" in
    performance) set_performance ;;
    powersave) set_powersave ;;
    auto)
        # Auto-detect based on AC power
        if [[ -d /sys/class/power_supply/BAT0 ]]; then
            if [[ "$(cat /sys/class/power_supply/BAT0/status)" == "Discharging" ]]; then
                set_powersave
            else
                set_performance
            fi
        else
            set_performance
        fi
        ;;
    *) echo "Usage: $0 {performance|powersave|auto}"; exit 1 ;;
esac
EOF
    chmod +x "${pkgdir}/usr/share/orionos/scripts/performance-mode.sh"

    log_info "OrionOS Desktop Environment installed successfully"
}
