    rounding = 12
    blur {
        enabled = true
        size = 8
        passes = 3
        new_optimizations = true
        xray = true
    }
    shadow {
        enabled = true
        range = 30
        render_power = 3
        color = rgba(0, 0, 0, 0.4)
    }
