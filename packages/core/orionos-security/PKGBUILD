# Maintainer: Yousef Elsharkawy <yousefelsharkawy26@gmail.com>
pkgname=orionos-security
pkgver=0.1.0
pkgrel=1
pkgdesc="OrionOS security stack - AppArmor, firewall, encryption, and hardening"
arch=('any')
url="https://github.com/yousefelsharkawy26/OrionOS-Linux-Distro"
license=('GPL3')
depends=(
    'apparmor'
    'apparmor-profiles'
    'apparmor-utils'
    'audit'
    'firewalld'
    'usbguard'
    'usbguard-dbus'
    'iptables-nft'
    'nftables'
    'ipset'
    'opensc'
    'tpm2-tools'
    'tpm2-tss'
    'clevis'
    'openssl'
    'gnupg'
    'libpwquality'
    'pam'
    'pambase'
    'sudo'
    'fail2ban'
    'rkhunter'
    'chkrootkit'
    'libseccomp'
    'seccomp'
    'bind'
    'dnscrypt-proxy'
)
optdepends=(
    'selinux-refpolicy-arch: SELinux policies'
    'selinux-alpm-hook: SELinux pacman hook'
    'aide: File integrity checker'
    'clamav: Antivirus'
)
conflicts=('orionos-security-git')
provides=('orionos-security')
backup=(
    'etc/apparmor.d/local/orionos-local'
    'etc/firewalld/zones/orionos.xml'
    'etc/usbguard/rules.conf'
    'etc/security/faillock.conf'
    'etc/audit/rules.d/orionos.rules'
    'etc/dnscrypt-proxy/dnscrypt-proxy.toml'
    'etc/pam.d/system-auth'
    'etc/sudoers.d/orionos'
    'etc/sysctl.d/98-security.conf'
    'etc/fail2ban/jail.d/orionos.conf'
)

package() {
    # Base directories
    install -d "$pkgdir/etc/apparmor.d/local"
    install -d "$pkgdir/etc/apparmor.d/abstractions"
    install -d "$pkgdir/etc/firewalld/zones"
    install -d "$pkgdir/etc/firewalld/services"
    install -d "$pkgdir/etc/usbguard"
    install -d "$pkgdir/etc/security"
    install -d "$pkgdir/etc/audit/rules.d"
    install -d "$pkgdir/etc/dnscrypt-proxy"
    install -d "$pkgdir/etc/pam.d"
    install -d "$pkgdir/etc/sudoers.d"
    install -d "$pkgdir/etc/fail2ban/jail.d"
    install -d "$pkgdir/etc/rkhunter"
    install -d "$pkgdir/usr/lib/systemd/system"
    install -d "$pkgdir/usr/lib/sysctl.d"
    install -d "$pkgdir/usr/bin"
    install -d "$pkgdir/usr/share/orionos/security"
    install -d "$pkgdir/usr/share/doc/orionos-security"
    install -d "$pkgdir/etc/polkit-1/rules.d"

    # ==================================================================
    # AppArmor local profile extensions
    # ==================================================================
    cat > "$pkgdir/etc/apparmor.d/local/orionos-local" << 'EOF'
# OrionOS AppArmor local profile extensions
# These extend the base profiles with OrionOS-specific rules

# Allow OrionOS CLI tool to manage system
/usr/bin/orionos-cli rUx,
/usr/share/orionos/** r,

# Allow performance daemon
/usr/bin/orionos-perfd rUx,

# Allow update daemon to manage packages
/usr/bin/orionos-updated rUx,
/etc/pacman.conf r,
/var/cache/pacman/** rwk,

# Allow Btrfs operations for snapshot management
/sbin/btrfs rUx,
/bin/btrfs rUx,
EOF

    # ==================================================================
    # Firewalld zone configuration
    # ==================================================================
    cat > "$pkgdir/etc/firewalld/zones/orionos.xml" << 'EOF'
<?xml version="1.0" encoding="utf-8"?>
<zone>
  <short>OrionOS</short>
  <description>OrionOS default firewall zone. Balanced security for desktop use.</description>
  <service name="ssh"/>
  <service name="dhcpv6-client"/>
  <service name="mdns"/>
  <service name="samba-client"/>
  <rule family="ipv4">
    <protocol value="icmp"/>
    <accept/>
  </rule>
  <rule family="ipv6">
    <protocol value="ipv6-icmp"/>
    <accept/>
  </rule>
  <rule family="ipv4">
    <source address="172.16.0.0/12"/>
    <accept/>
  </rule>
  <rule family="ipv4">
    <source address="192.168.0.0/16"/>
    <accept/>
  </rule>
  <rule family="ipv4">
    <source address="10.0.0.0/8"/>
    <accept/>
  </rule>
  <rule family="ipv6">
    <source address="fe80::/10"/>
    <accept/>
  </rule>
</zone>
EOF

    # ==================================================================
    # Firewalld services
    # ==================================================================
    cat > "$pkgdir/etc/firewalld/services/orionos-sync.xml" << 'EOF'
<?xml version="1.0" encoding="utf-8"?>
<service>
  <short>OrionOS Sync</short>
  <description>OrionOS cross-device synchronization protocol</description>
  <port protocol="tcp" port="42000-42010"/>
  <port protocol="udp" port="42000-42010"/>
</service>
EOF

    # ==================================================================
    # USBGuard configuration
    # ==================================================================
    cat > "$pkgdir/etc/usbguard/rules.conf" << 'EOF'
# OrionOS USBGuard default policy
# Default: block all new USB devices, allow configured ones

# Allow USB hubs (required for most systems)
allow id 1d6b:* serial "*" name "* USB *" hash "*" parent-hash "*" via-port "*" with-interface { 09:00:* }

# Allow HID devices (keyboards, mice) - only if already present at boot
allow with-interface equals { 03:01:02 } # Boot keyboard
allow with-interface equals { 03:01:01 } # Boot mouse

# Block everything else by default
block
EOF

    cat > "$pkgdir/etc/usbguard/usbguard-daemon.conf" << 'EOF'
# OrionOS USBGuard daemon configuration
RuleFile=/etc/usbguard/rules.conf
ImplicitPolicyTarget=block
PresentDevicePolicy=apply-policy
PresentControllerPolicy=keep
InsertedDevicePolicy=apply-policy
RestoreControllerDeviceState=false
DeviceBackend=uevent
IPCAllowedUsers=root
IPCAllowedGroups=wheel
EOF

    # ==================================================================
    # Fail2ban jail configuration
    # ==================================================================
    cat > "$pkgdir/etc/fail2ban/jail.d/orionos.conf" << 'EOF'
[DEFAULT]
findtime = 10m
maxretry = 5
bantime = 1h
backend = systemd
banaction = nftables-multiport
chain = input

[sshd]
enabled = true
port = ssh
filter = sshd
logpath = /var/log/auth.log
maxretry = 3
bantime = 24h

[pam-generic]
enabled = true
filter = pam-generic
port = all
banaction = nftables-multiport
logpath = /var/log/auth.log
EOF

    # ==================================================================
    # Audit rules for OrionOS
    # ==================================================================
    cat > "$pkgdir/etc/audit/rules.d/orionos.rules" << 'EOF'
# OrionOS audit rules
# Delete all existing rules
-D

# Set buffer size
-b 8192

# Monitor system calls
-a always,exit -F arch=b64 -S setuid -S setgid -S setreuid -S setregid -k privilege_escalation
-a always,exit -F arch=b64 -S execve -C uid!=euid -F euid=0 -k privilege_escalation
-a always,exit -F arch=b64 -S init_module -S finit_module -S delete_module -k kernel_modules

# Monitor authentication
-w /etc/shadow -p wa -k identity_changes
-w /etc/passwd -p wa -k identity_changes
-w /etc/gshadow -p wa -k identity_changes
-w /etc/group -p wa -k identity_changes
-w /etc/security/ -p wa -k identity_changes
-w /etc/pam.d/ -p wa -k authentication_changes

# Monitor sudoers
-w /etc/sudoers -p wa -k sudoers_changes
-w /etc/sudoers.d/ -p wa -k sudoers_changes

# Monitor SSH configuration
-w /etc/ssh/sshd_config -p wa -k sshd_config
-w /etc/ssh/sshd_config.d/ -p wa -k sshd_config

# Monitor cron jobs
-w /etc/cron.d/ -p wa -k cron_changes
-w /etc/cron.daily/ -p wa -k cron_changes
-w /etc/cron.hourly/ -p wa -k cron_changes
-w /etc/cron.weekly/ -p wa -k cron_changes
-w /etc/crontab -p wa -k cron_changes

# Monitor pacman (package manager)
-w /var/cache/pacman/ -p wa -k package_manager
-w /etc/pacman.conf -p wa -k package_manager

# Monitor boot files
-w /boot/ -p wa -k boot_changes
-w /etc/systemd/ -p wa -k systemd_changes

# Monitor AppArmor
-w /etc/apparmor/ -p wa -k apparmor_changes
-w /etc/apparmor.d/ -p wa -k apparmor_changes

# Make the configuration immutable (requires reboot to change)
-e 2
EOF

    # ==================================================================
    # DNS encryption configuration (dnscrypt-proxy)
    # ==================================================================
    cat > "$pkgdir/etc/dnscrypt-proxy/dnscrypt-proxy.toml" << 'EOF'
# OrionOS DNS encryption configuration
# Uses DNS-over-HTTPS with multiple resolvers

server_names = ['cloudflare', 'cloudflare-ipv6', 'quad9-dnscrypt-ip4-filter-pri', 'quad9-dnscrypt-ip6-filter-pri']

listen_addresses = ['127.0.0.1:53', '[::1]:53']
max_clients = 250
ipv4_servers = true
ipv6_servers = true
dnscrypt_servers = true
doh_servers = true
require_dnssec = true
require_nolog = true
require_nofilter = false
cached = true

[sources]
  [sources.'public-resolvers']
  urls = ['https://raw.githubusercontent.com/DNSCrypt/dnscrypt-resolvers/master/v3/public-resolvers.md', 'https://download.dnscrypt.info/resolvers-list/v3/public-resolvers.md']
  cache_file = 'public-resolvers.md'
  minisign_key = 'RWQf6LRCGA9i53mlYecO4IzT51TGPpvWucNSCh1CBM0QTaLn73Y7GFO3'
  refresh_delay = 72
  prefix = ''

  [sources.'relays']
  urls = ['https://raw.githubusercontent.com/DNSCrypt/dnscrypt-resolvers/master/v3/relays.md', 'https://download.dnscrypt.info/resolvers-list/v3/relays.md']
  cache_file = 'relays.md'
  minisign_key = 'RWQf6LRCGA9i53mlYecO4IzT51TGPpvWucNSCh1CBM0QTaLn73Y7GFO3'
  refresh_delay = 72
  prefix = ''

[query_log]
  file = '/var/log/dnscrypt-proxy/query.log'
  format = 'ltsv'

[nx_log]
  file = '/var/log/dnscrypt-proxy/nx.log'
  format = 'ltsv'

[blocked_names]
  blocked_names_file = '/etc/dnscrypt-proxy/blocked-names.txt'

[scheduling]
  timeout = 5000
  keepalive = 30
EOF

    # ==================================================================
    # Faillock configuration
    # ==================================================================
    cat > "$pkgdir/etc/security/faillock.conf" << 'EOF'
# OrionOS faillock configuration
dir = /var/run/faillock
audit
silent
no_log_info
deny = 5
fail_interval = 900
unlock_time = 600
even_deny_root
root_unlock_time = 600
EOF

    # ==================================================================
    # Sudoers configuration for OrionOS
    # ==================================================================
    cat > "$pkgdir/etc/sudoers.d/orionos" << 'EOF'
# OrionOS sudo configuration

# Allow wheel group full sudo access
%wheel ALL=(ALL:ALL) ALL

# Allow passwordless sudo for specific system maintenance
%wheel ALL=(ALL) NOPASSWD: /usr/bin/btrfs *
%wheel ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart *
%wheel ALL=(ALL) NOPASSWD: /usr/bin/systemctl start *
%wheel ALL=(ALL) NOPASSWD: /usr/bin/systemctl stop *
%wheel ALL=(ALL) NOPASSWD: /usr/bin/systemctl status *
%wheel ALL=(ALL) NOPASSWD: /usr/bin/pacman -Syu
%wheel ALL=(ALL) NOPASSWD: /usr/bin/orionos-cli *

# Defaults
Defaults env_reset
Defaults mail_badpass
Defaults secure_path="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Defaults timestamp_timeout=15
Defaults logfile="/var/log/sudo.log"
Defaults lecture=never
EOF
    chmod 440 "$pkgdir/etc/sudoers.d/orionos"

    # ==================================================================
    # PAM configuration - system-auth
    # ==================================================================
    cat > "$pkgdir/etc/pam.d/system-auth" << 'EOF'
# OrionOS PAM system-auth configuration
#%PAM-1.0

auth       required                    pam_faillock.so      preauth silent deny=5 unlock_time=600
auth       [success=1 default=bad]     pam_unix.so          try_first_pass nullok
auth       [default=die]               pam_faillock.so      authfail deny=5 unlock_time=600
auth       optional                    pam_permit.so
auth       required                    pam_env.so

account    required                    pam_unix.so
account    required                    pam_faillock.so
account    optional                    pam_permit.so

password   required                    pam_pwquality.so     retry=3 minlen=12 dcredit=-1 ucredit=-1 ocredit=-1 lcredit=-1 difok=4
password   [success=1 default=bad]     pam_unix.so          try_first_pass use_authtok nullok sha512 shadow rounds=500000
password   optional                    pam_permit.so

session    required                    pam_limits.so
session    required                    pam_unix.so
session    optional                    pam_permit.so
EOF

    # ==================================================================
    # Security sysctl
    # ==================================================================
    cat > "$pkgdir/etc/sysctl.d/98-security.conf" << 'EOF'
# OrionOS Security Hardening
# Kernel parameters for enhanced security

# Disable source routing
net.ipv4.conf.all.accept_source_route = 0
net.ipv4.conf.default.accept_source_route = 0
net.ipv6.conf.all.accept_source_route = 0
net.ipv6.conf.default.accept_source_route = 0

# Disable ICMP redirects
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0
net.ipv6.conf.all.accept_redirects = 0
net.ipv6.conf.default.accept_redirects = 0
net.ipv4.conf.all.send_redirects = 0
net.ipv4.conf.default.send_redirects = 0

# Ignore ICMP echo requests (ping)
net.ipv4.icmp_echo_ignore_broadcasts = 1
net.ipv4.icmp_ignore_bogus_error_responses = 1

# Enable SYN cookies
net.ipv4.tcp_syncookies = 1

# Enable reverse path filtering
net.ipv4.conf.all.rp_filter = 1
net.ipv4.conf.default.rp_filter = 1

# Disable IPv6 router solicitations
net.ipv6.conf.all.router_solicitations = 0
net.ipv6.conf.default.router_solicitations = 0

# Enable ASLR
kernel.randomize_va_space = 2

# Restrict ptrace
kernel.yama.ptrace_scope = 2

# Restrict dmesg
kernel.dmesg_restrict = 1

# Restrict kernel pointers
kernel.kptr_restrict = 2

# Disable kexec
kernel.kexec_load_disabled = 1

# Harden BPF
net.core.bpf_jit_harden = 2

# Restrict userfaultfd
vm.unprivileged_userfaultfd = 0

# Disable autobind for IPv6
net.ipv6.ip6frag_low_thresh = 131072
net.ipv4.ipfrag_low_thresh = 196608
EOF

    # ==================================================================
    # Polkit rules for OrionOS
    # ==================================================================
    cat > "$pkgdir/etc/polkit-1/rules.d/99-orionos.rules" << 'EOF'
// OrionOS polkit rules
// Allow certain actions without password for wheel group

polkit.addRule(function(action, subject) {
    // Allow wheel group to manage NetworkManager
    if (action.id.indexOf("org.freedesktop.NetworkManager.") == 0 &&
        subject.isInGroup("wheel")) {
        return polkit.Result.YES;
    }

    // Allow wheel group to manage Bluetooth
    if (action.id.indexOf("org.bluez.") == 0 &&
        subject.isInGroup("wheel")) {
        return polkit.Result.YES;
    }

    // Allow wheel group to manage power
    if (action.id.indexOf("org.freedesktop.login1.") == 0 &&
        subject.isInGroup("wheel")) {
        return polkit.Result.YES;
    }

    // Allow wheel group to mount/unmount
    if (action.id.indexOf("org.freedesktop.udisks2.") == 0 &&
        subject.isInGroup("wheel")) {
        return polkit.Result.YES;
    }
});
EOF

    # ==================================================================
    # RKHunter configuration
    # ==================================================================
    cat > "$pkgdir/etc/rkhunter/rkhunter.conf.local" << 'EOF'
# OrionOS RKHunter local configuration
DISABLE_TESTS=suspscan hidden_ports deleted_files packet_cap_apps apps
ALLOWHIDDENDIR=/etc/.java
ALLOWHIDDENDIR=/dev/.udev
ALLOWHIDDENDIR=/dev/.mdadm
ALLOWHIDDENFILE=/usr/share/man/man1/..1.gz
ALLOWHIDDENFILE=/etc/.java
ALLOWDEVFILE=/dev/shm/sem.*
EOF

    # ==================================================================
    # Notification sound script
    # ==================================================================
    cat > "$pkgdir/usr/share/orionos/security/security-alert.sh" << 'EOF'
#!/bin/bash
# OrionOS security alert notification

MESSAGE="$1"
SEVERITY="$2"

# Play appropriate sound
if [[ "$SEVERITY" == "critical" ]]; then
    paplay /usr/share/sounds/freedesktop/stereo/dialog-warning.oga 2>/dev/null || true
fi

# Send notification
dunstify -u "$SEVERITY" -a "OrionOS Security" "$MESSAGE"
EOF
    chmod 755 "$pkgdir/usr/share/orionos/security/security-alert.sh"

    # ==================================================================
    # Enable services via systemd presets
    # ==================================================================
    install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/system-preset/98-orionos-security.preset" << 'EOF'
enable apparmor.service
enable auditd.service
enable firewalld.service
enable usbguard.service
enable usbguard-dbus.service
enable fail2ban.service
enable dnscrypt-proxy.service
EOF

    # ==================================================================
    # Documentation
    # ==================================================================
    install -Dm644 /dev/stdin "$pkgdir/usr/share/doc/orionos-security/README" << 'EOF'
OrionOS Security Stack
=======================

This package provides comprehensive security for OrionOS:

- AppArmor: Mandatory Access Control profiles
- firewalld: Zone-based firewall with OrionOS defaults
- USBGuard: USB device access control
- fail2ban: Intrusion prevention for SSH
- auditd: System call auditing
- dnscrypt-proxy: Encrypted DNS
- faillock: Account lockout after failed attempts
- PAM hardening: Password quality and authentication rules
- sysctl hardening: Kernel security parameters
- polkit rules: Privilege management for wheel group

Services enabled by default:
- apparmor.service
- auditd.service
- firewalld.service
- usbguard.service
- fail2ban.service
- dnscrypt-proxy.service
EOF
}
