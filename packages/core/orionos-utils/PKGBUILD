    # ==================================================================
    # System status script
    # ==================================================================
    cat > "$pkgdir/usr/bin/orionos-status" << 'EOF'
#!/bin/bash
# OrionOS quick status display

echo ""
echo "  ╔═══════════════════════════════════════════╗"
echo "  ║          OrionOS System Status            ║"
echo "  ╚═══════════════════════════════════════════╝"
echo ""

# Uptime
echo "  Uptime:    $(uptime -p 2>/dev/null || echo 'unknown')"

# Load
echo "  Load:      $(cut -d' ' -f1-3 /proc/loadavg)"

# Memory
if command -v free &>/dev/null; then
    mem=$(free -h | awk '/^Mem:/ {print $3 "/" $2}')
    echo "  Memory:    $mem"
fi

# Disk
disk=$(df -h / | awk 'NR==2 {print $3 "/" $2 " (" $5 ")"}')
echo "  Disk:      $disk"

# Profile
if [[ -f /var/lib/orionos/performance.state ]]; then
    profile=$(python3 -c "import json; print(json.load(open('/var/lib/orionos/performance.state')).get('profile','default'))")
    echo "  Profile:   $profile"
fi

# Updates
if [[ -f /var/lib/orionos/update.state ]]; then
    updates=$(python3 -c "import json; print(json.load(open('/var/lib/orionos/update.state')).get('count',0))")
    echo "  Updates:   $updates available"
fi

# Network
if ip link show | grep -q "state UP"; then
    echo "  Network:   connected"
else
    echo "  Network:   disconnected"
fi

echo ""
EOF
    chmod 755 "$pkgdir/usr/bin/orionos-status"

    # ==================================================================
    # Documentation
    # ==================================================================
    install -Dm644 /dev/stdin "$pkgdir/usr/share/doc/orionos-utils/README" << 'EOF'
OrionOS Utilities
==================

This package provides OrionOS CLI tools:

Commands:
- orionos-cli: Main command-line interface
  - info: System information
  - performance: Performance profile management
  - update: System update management
  - snapshot: Btrfs snapshot management
  - doctor: System health checks
  - package: Package management

- orionos-status: Quick system status display

Shell completions:
- Bash: /usr/share/bash-completion/completions/orionos-cli
- Zsh: /usr/share/zsh/site-functions/_orionos-cli
EOF
}
