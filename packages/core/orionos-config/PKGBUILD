# Maintainer: Yousef Elsharkawy <yousefelsharkawy26@gmail.com>
pkgname=orionos-config
pkgver=0.1.0
pkgrel=1
pkgdesc="OrionOS base system configuration"
arch=('any')
url="https://github.com/yousefelsharkawy26/OrionOS-Linux-Distro"
license=('GPL3')
depends=(
    'pacman'
    'filesystem'
    'systemd'
    'base'
    'base-devel'
    'bash'
    'coreutils'
    'file'
    'findutils'
    'gawk'
    'gcc-libs'
    'gettext'
    'glibc'
    'grep'
    'gzip'
    'iproute2'
    'iputils'
    'licenses'
    'pciutils'
    'procps-ng'
    'psmisc'
    'sed'
    'shadow'
    'tar'
    'util-linux'
    'which'
    'btrfs-progs'
    'grub'
    'efibootmgr'
    'dosfstools'
    'os-prober'
    'mtools'
    'networkmanager'
    'iwd'
    'i2c-tools'
    'usbutils'
    'linux-firmware'
    'mkinitcpio'
    'mkinitcpio-busybox'
    'nano'
    'vim'
    'man-db'
    'man-pages'
    'texinfo'
    'openssh'
    'cronie'
    'rsync'
    'wget'
    'curl'
    'git'
    'zram-generator'
)
optdepends=(
    'orionos-desktop: Desktop environment'
    'orionos-security: Security stack'
    'orionos-services: System services'
)
conflicts=('orionos-config-git')
provides=('orionos-config')
replaces=()
backup=(
    'etc/sysctl.d/99-orionos.conf'
    'etc/mkinitcpio.conf.d/orionos.conf'
    'etc/pacman.conf.d/orionos.conf'
    'etc/NetworkManager/NetworkManager.conf'
    'etc/systemd/zram-generator.conf'
    'etc/default/grub'
    'etc/environment.d/90-orionos.conf'
    'etc/modprobe.d/orionos.conf'
    'etc/udev/rules.d/99-orionos.rules'
    'etc/systemd/journald.conf.d/orionos.conf'
    'etc/systemd/timesyncd.conf'
)

package() {
    # Base directory structure
    install -d "$pkgdir/etc/sysctl.d"
    install -d "$pkgdir/etc/mkinitcpio.conf.d"
    install -d "$pkgdir/etc/pacman.conf.d"
    install -d "$pkgdir/etc/NetworkManager"
    install -d "$pkgdir/etc/systemd"
    install -d "$pkgdir/etc/default"
    install -d "$pkgdir/etc/environment.d"
    install -d "$pkgdir/etc/modprobe.d"
    install -d "$pkgdir/etc/udev/rules.d"
    install -d "$pkgdir/etc/systemd/journald.conf.d"
    install -d "$pkgdir/etc/pacman.d/hooks"
    install -d "$pkgdir/usr/lib/systemd/system"
    install -d "$pkgdir/usr/share/orionos"
    install -d "$pkgdir/usr/share/doc/orionos-config"
    install -d "$pkgdir/etc/skel"

    # ==================================================================
    # Kernel tuning - performance optimizations
    # ==================================================================
    cat > "$pkgdir/etc/sysctl.d/99-orionos.conf" << 'EOF'
# OrionOS Kernel Performance Tuning
# BORE Scheduler parameters
kernel.sched_bore=1
kernel.sched_burst_penalty_offset=22
kernel.sched_burst_penalty_scale=1280
kernel.sched_burst_cache_lifetime=60000000

# Virtual memory
vm.swappiness=10
vm.vfs_cache_pressure=50
vm.dirty_ratio=10
vm.dirty_background_ratio=5
vm.page-cluster=3
vm.dirty_expire_centisecs=500
vm.dirty_writeback_centisecs=100

# Transparent Hugepages
vm.transparent_hugepage=madvise

# Networking - TCP BBR
net.core.default_qdisc=cake
net.ipv4.tcp_congestion_control=bbr
net.ipv4.tcp_notsent_lowat=16384
net.core.netdev_max_backlog=16384
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_tw_reuse=1
net.ipv4.tcp_fin_timeout=10
net.ipv4.tcp_keepalive_time=60
net.ipv4.tcp_keepalive_intvl=10
net.ipv4.tcp_keepalive_probes=6

# File handles
fs.file-max=2097152
fs.inotify.max_user_watches=524288
fs.inotify.max_user_instances=8192

# IPC
kernel.msgmax=65536
kernel.msgmnb=65536

# Panic reboot
kernel.panic=10
kernel.panic_on_oops=1

# Disable core dumps for security
fs.suid_dumpable=0

# ASLR
kernel.randomize_va_space=2
EOF

    # ==================================================================
    # Mkinitcpio configuration for Btrfs + encryption support
    # ==================================================================
    cat > "$pkgdir/etc/mkinitcpio.conf.d/orionos.conf" << 'EOF'
# OrionOS initramfs configuration
MODULES=(btrfs zlib zstd raid6 raid456 dm_mod dm_crypt aes_x86_64 crc32c-intel xhci_hcd nvme)

BINARIES=()

FILES=()

HOOKS=(base udev autodetect keyboard keymap modconf block encrypt filesystems btrfs fsck)

COMPRESSION="zstd"
COMPRESSION_OPTIONS=(-T0 -18)
EOF

    # ==================================================================
    # Pacman configuration extensions
    # ==================================================================
    cat > "$pkgdir/etc/pacman.conf.d/orionos.conf" << 'EOF'
# OrionOS Pacman Configuration

[options]
CacheDir    = /var/cache/pacman/pkg/
CacheDir    = /var/cache/pacman/orionos/
CleanMethod = KeepInstalled
UseDelta    = 0.7

# Parallel downloads
ParallelDownloads = 8

# Color output
Color

# Check space
CheckSpace

# Verbose package lists
VerbosePkgLists

# Disable password for wheel group in sudo context
# (handled by sudoers)

[orionos]
SigLevel = Required DatabaseOptional
Server = https://repo.orionos.org/$repo/os/$arch
EOF

    # ==================================================================
    # NetworkManager configuration with iwd
    # ==================================================================
    cat > "$pkgdir/etc/NetworkManager/NetworkManager.conf" << 'EOF'
[main]
plugins=keyfile
systemd-resolved=true
dns=systemd-resolved

[device]
wifi.backend=iwd

[connection]
ipv6.method=auto
ipv4.method=auto

[logging]
level=INFO
EOF

    # ==================================================================
    # zRAM configuration
    # ==================================================================
    cat > "$pkgdir/etc/systemd/zram-generator.conf" << 'EOF'
# OrionOS zRAM Configuration
[zram0]
zram-size = min(ram / 2, 8192)
compression-algorithm = zstd
swap-priority = 100
fs-type = swap
EOF

    # ==================================================================
    # GRUB defaults for OrionOS
    # ==================================================================
    cat > "$pkgdir/etc/default/grub" << 'EOF'
# OrionOS GRUB defaults
GRUB_DEFAULT=0
GRUB_TIMEOUT=5
GRUB_DISTRIBUTOR="OrionOS"
GRUB_CMDLINE_LINUX_DEFAULT="quiet splash loglevel=3 mitigations=auto"
GRUB_CMDLINE_LINUX=""

# Preload modules for Btrfs and encryption
GRUB_PRELOAD_MODULES="part_gpt part_msdos btrfs ext2 fat"

# Terminal configuration
GRUB_TERMINAL_INPUT=console
GRUB_GFXMODE=auto
GRUB_GFXPAYLOAD_LINUX=keep

# Bootloader ID
GRUB_DEFAULT=saved
GRUB_SAVEDEFAULT=true

# Btrfs subvolume awareness
GRUB_BTRFS_OVERRIDE_BOOT_PARTITION_DETECTION=true

# Theme
GRUB_THEME="/boot/grub/themes/orionos/theme.txt"

# Disable recovery mode
GRUB_DISABLE_RECOVERY=true
EOF

    # ==================================================================
    # Environment variables
    # ==================================================================
    cat > "$pkgdir/etc/environment.d/90-orionos.conf" << 'EOF'
# OrionOS environment defaults
EDITOR=vim
VISUAL=vim
PAGER=less

# Wayland
MOZ_ENABLE_WAYLAND=1
QT_QPA_PLATFORM=wayland
SDL_VIDEODRIVER=wayland
_JAVA_AWT_WM_NONREPARENTING=1
XDG_SESSION_TYPE=wayland

# GPU
MESA_SHADER_CACHE_MAX_SIZE=1GB
__GL_SHADER_DISK_CACHE=1
__GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1

# GTK
GTK_THEME=OrionOS-Dark

# Performance
MESA_NO_ERROR=1
EOF

    # ==================================================================
    # Kernel module configuration
    # ==================================================================
    cat > "$pkgdir/etc/modprobe.d/orionos.conf" << 'EOF'
# OrionOS kernel module configuration

# GPU drivers - load early
options amdgpu si_support=1 cik_support=1
options i915 enable_fbc=1 enable_guc=3
options nouveau modeset=0

# Audio
options snd-hda-intel power_save=1 power_save_controller=Y

# Disable PC speaker
blacklist pcspkr
blacklist snd_pcsp

# Btrfs optimization
options btrfs compress=zstd:3
EOF

    # ==================================================================
    # udev rules for hardware optimization
    # ==================================================================
    cat > "$pkgdir/etc/udev/rules.d/99-orionos.rules" << 'EOF'
# OrionOS udev rules

# Reduce latency for input devices
ACTION=="add|change", SUBSYSTEM=="input", KERNEL=="event*", ATTR{device/power/control}="on"

# USB autosuspend for non-input devices
ACTION=="add", SUBSYSTEM=="usb", TEST=="power/control", ATTR{power/control}="auto"
ACTION=="add", SUBSYSTEM=="usb", ATTR{bInterfaceClass}=="03", ATTR{power/control}="on"

# NVMe power management
ACTION=="add|change", SUBSYSTEM=="nvme", ATTR{power/control}="auto"

# SATA link power management
ACTION=="add|change", SUBSYSTEM=="scsi_host", KERNEL=="host*", ATTR{link_power_management_policy}="min_power"
EOF

    # ==================================================================
    # Journald configuration
    # ==================================================================
    cat > "$pkgdir/etc/systemd/journald.conf.d/orionos.conf" << 'EOF'
[Journal]
Storage=persistent
SystemMaxUse=500M
SystemMaxFileSize=50M
MaxRetentionSec=1month
EOF

    # ==================================================================
    # NTP configuration
    # ==================================================================
    cat > "$pkgdir/etc/systemd/timesyncd.conf" << 'EOF'
[Time]
NTP=0.arch.pool.ntp.org 1.arch.pool.ntp.org 2.arch.pool.ntp.org 3.arch.pool.ntp.org
FallbackNTP=0.pool.ntp.org 1.pool.ntp.org
EOF

    # ==================================================================
    # Pacman hooks for system maintenance
    # ==================================================================
    cat > "$pkgdir/etc/pacman.d/hooks/99-update-grub.hook" << 'EOF'
[Trigger]
Operation = Upgrade
Type = Package
Target = linux
Target = linux-cachyos
Target = linux-lts

[Action]
Description = Updating GRUB configuration...
When = PostTransaction
Exec = /usr/bin/grub-mkconfig -o /boot/grub/grub.cfg
EOF

    cat > "$pkgdir/etc/pacman.d/hooks/99-btrfs-defrag.hook" << 'EOF'
[Trigger]
Operation = Install
Operation = Upgrade
Operation = Remove
Type = Package
Target = *

[Action]
Description = Btrfs filesystem maintenance...
When = PostTransaction
Exec = /usr/bin/bash -c '/usr/bin/btrfs filesystem defragment -r / >/dev/null 2>&1 || true'
AbortOnFail = no
NeedsTargets
EOF

    # ==================================================================
    # Default user skeleton
    # ==================================================================
    cat > "$pkgdir/etc/skel/.bashrc" << 'EOF'
# OrionOS default bashrc

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# Prompt
PS1='\[\033[38;5;208m\][\u@\h \W]\$\[\033[0m\] '

# Aliases
alias ls='ls --color=auto'
alias ll='ls -la'
alias grep='grep --color=auto'
alias pacman='pacman --color=auto'
alias update='sudo orionos-cli update --apply'

# History
HISTSIZE=10000
HISTFILESIZE=20000
HISTCONTROL=ignoreboth
shopt -s histappend

# Completion
if [[ -r /usr/share/bash-completion/bash_completion ]]; then
    . /usr/share/bash-completion/bash_completion
fi

# PATH
export PATH="$HOME/.local/bin:$PATH"
EOF

    # ==================================================================
    # Version info
    # ==================================================================
    echo "OrionOS Config Package v$pkgver-$pkgrel" > "$pkgdir/usr/share/orionos/config-version"
    install -Dm644 /dev/stdin "$pkgdir/usr/share/doc/orionos-config/README" << 'EOF'
OrionOS Base Configuration
===========================

This package provides the base system configuration for OrionOS including:
- Kernel sysctl tuning (BORE scheduler, BBR, memory management)
- Initramfs configuration for Btrfs and encryption
- Pacman configuration with parallel downloads
- NetworkManager with iwd backend
- zRAM swap configuration
- GRUB bootloader defaults
- Environment variables for Wayland
- Kernel module configuration
- udev rules for power management
- System maintenance hooks
- Default user configuration
EOF
}
