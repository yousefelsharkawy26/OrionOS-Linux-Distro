# Maintainer: OrionOS Team <team@orionos.org>
pkgname=orionos-config
pkgver=0.1.0
pkgrel=1
pkgdesc="OrionOS System Configuration and Defaults"
arch=('any')
url="https://orionos.org"
license=('GPL-3.0')
depends=()
source=()
sha256sums=()

package() {
    # System configuration
    install -d "${pkgdir}/etc"
    install -d "${pkgdir}/etc/default"
    install -d "${pkgdir}/etc/profile.d"
    install -d "${pkgdir}/etc/security/limits.d"
    install -d "${pkgdir}/etc/sysctl.d"
    install -d "${pkgdir}/etc/tmpfiles.d"
    install -d "${pkgdir}/etc/modprobe.d"
    install -d "${pkgdir}/etc/mkinitcpio.conf.d"

    # OrionOS system defaults
    cat > "${pkgdir}/etc/orionos-release" << EOF
NAME="OrionOS"
PRETTY_NAME="OrionOS"
ID=orionos
ID_LIKE=arch
BUILD_ID=rolling
ANSI_COLOR="0;38;2;0;180;216"
HOME_URL="https://orionos.org/"
DOCUMENTATION_URL="https://docs.orionos.org/"
SUPPORT_URL="https://forum.orionos.org/"
BUG_REPORT_URL="https://bugs.orionos.org/"
LOGO=orionos-logo
EOF

    # OS release (compatibility)
    ln -sf /etc/orionos-release "${pkgdir}/etc/os-release"

    # Issue
    cat > "${pkgdir}/etc/issue" << 'EOF'
OrionOS 
 \l

EOF

    # Motd
    cat > "${pkgdir}/etc/motd" << 'EOF'
    ____  ____  _/_/____  ____  ___  ____
   / __ \/ __ `/ / ___/ __ \/ __ \/ _ \/ __ \
  / /_/ / /_/ / / /__/ / / / / / /  __/ / / /
 / .___/\__,_/_/\___/_/ /_/_/ /_/\___/_/ /_/
/_/

Welcome to OrionOS!

EOF

    # sysctl performance tuning
    cat > "${pkgdir}/etc/sysctl.d/99-orionos-performance.conf" << 'EOF'
# OrionOS Performance Optimizations
# Do not edit this file directly; use /etc/sysctl.d/ for custom overrides

# VM optimizations
vm.swappiness=10
vm.vfs_cache_pressure=50
vm.dirty_ratio=15
vm.dirty_background_ratio=5
vm.page-cluster=3
vm.dirty_expire_centisecs=1500
vm.dirty_writeback_centisecs=300
vm.zone_reclaim_mode=0
vm.overcommit_memory=1
vm.overcommit_ratio=50

# Kernel scheduler
kernel.sched_cfs_bandwidth_slice_us=3000
kernel.sched_latency_ns=1000000
kernel.sched_min_granularity_ns=100000
kernel.sched_wakeup_granularity_ns=50000
kernel.sched_migration_cost_ns=250000
kernel.sched_nr_migrate=32

# Network optimizations
net.core.netdev_max_backlog=65536
net.core.somaxconn=8192
net.ipv4.tcp_max_syn_backlog=8192
net.ipv4.tcp_tw_reuse=1
net.ipv4.tcp_fin_timeout=10
net.ipv4.tcp_keepalive_time=60
net.ipv4.tcp_keepalive_intvl=10
net.ipv4.tcp_keepalive_probes=6
net.ipv4.tcp_slow_start_after_idle=0
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_congestion_control=bbr
net.core.rmem_max=134217728
net.core.wmem_max=134217728
net.ipv4.tcp_rmem=4096 87380 134217728
net.ipv4.tcp_wmem=4096 65536 134217728

# File system
fs.file-max=2097152
fs.inotify.max_user_watches=524288
fs.aio-max-nr=1048576

# Security
kernel.kptr_restrict=2
kernel.dmesg_restrict=1
kernel.yama.ptrace_scope=1
kernel.perf_event_paranoid=2
kernel.kexec_load_disabled=1
kernel.unprivileged_bpf_disabled=1
net.core.bpf_jit_harden=2
EOF

    # Security limits
    cat > "${pkgdir}/etc/security/limits.d/99-orionos.conf" << 'EOF'
# OrionOS resource limits
# Allow audio group real-time priority
@audio - rtprio 95
@audio - memlock unlimited

# Allow realtime for pipewire
@realtime - rtprio 98
@realtime - memlock unlimited

# Increase file descriptor limits
* soft nofile 1048576
* hard nofile 1048576
EOF

    # tmpfiles for runtime directories
    cat > "${pkgdir}/etc/tmpfiles.d/orionos.conf" << 'EOF'
# OrionOS runtime directories
D /run/orionos 0755 root root -
D /run/orionos/updates 0755 root root -
D /run/orionos/snapshots 0755 root root -
D /var/lib/orionos 0755 root root -
D /var/cache/orionos 0755 root root -
D /var/log/orionos 0755 root root -
D /var/lib/orionos/ai 0755 root root -
D /var/lib/orionos/ai/models 0755 root root -
EOF

    # Module blacklist for problematic hardware
    cat > "${pkgdir}/etc/modprobe.d/orionos-blacklist.conf" << 'EOF'
# OrionOS module blacklist
# Blacklist problematic or conflicting modules

# Disable PC speaker beep
blacklist pcspkr
blacklist snd_pcsp

# Disable watchdogs (can cause issues)
blacklist iTCO_wdt
blacklist iTCO_vendor_support
blacklist sp5100_tco
EOF

    # Mkinitcpio configuration
    cat > "${pkgdir}/etc/mkinitcpio.conf.d/orionos.conf" << 'EOF'
# OrionOS initramfs configuration
MODULES=(btrfs nvidia nvidia_modeset nvidia_uvm nvidia_drm)
BINARIES=()
FILES=()
HOOKS=(base udev autodetect modconf kms keyboard keymap consolefont block filesystems fsck)
COMPRESSION="zstd"
COMPRESSION_OPTIONS=(-19)
EOF

    # Environment variables
    cat > "${pkgdir}/etc/profile.d/orionos.sh" << 'EOF'
# OrionOS environment configuration

# Default editor
export EDITOR=nvim
export VISUAL=code

# Better font rendering
export FREETYPE_PROPERTIES="truetype:interpreter-version=40"

# Java applications on Wayland
export _JAVA_AWT_WM_NONREPARENTING=1

# Qt platform
export QT_QPA_PLATFORM=wayland
export QT_QPA_PLATFORMTHEME=qt5ct
export QT_AUTO_SCREEN_SCALE_FACTOR=1
export QT_WAYLAND_DISABLE_WINDOWDECORATION=1

# GTK theming
export GTK_THEME=OrionOS-Dark
export GTK2_RC_FILES=/usr/share/themes/OrionOS-Dark/gtk-2.0/gtkrc

# Electron apps on Wayland
export ELECTRON_OZONE_PLATFORM_HINT=wayland

# SDL2 on Wayland
export SDL_VIDEODRIVER=wayland

# Firefox on Wayland
export MOZ_ENABLE_WAYLAND=1
export MOZ_USE_XINPUT2=1

# Chrome/Chromium on Wayland
export CHROMIUM_FLAGS="--ozone-platform=wayland --enable-features=UseOzonePlatform"

# Hyprland socket
export HYPRLAND_INSTANCE_SIGNATURE=""

# Add OrionOS utilities to PATH
export PATH="/usr/share/orionos/bin:$PATH"

# Performance environment
export MESA_SHADER_CACHE_MAX_SIZE=1GB
export __GL_SHADER_DISK_CACHE=1
export __GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1
export __GL_THREADED_OPTIMIZATIONS=1
export __GL_SYNC_TO_VBLANK=0

# Vulkan device selection
export VK_ICD_FILENAMES=""

# Gaming performance
export CPU_DMA_LATENCY=0
export WINE_CPU_TOPOLOGY="auto"
EOF

    # Input device configuration
    install -d "${pkgdir}/etc/X11/xorg.conf.d"
    cat > "${pkgdir}/etc/X11/xorg.conf.d/99-orionos-input.conf" << 'EOF'
# OrionOS input configuration
Section "InputClass"
    Identifier "touchpad"
    Driver "libinput"
    MatchIsTouchpad "on"
    Option "Tapping" "on"
    Option "TappingDrag" "on"
    Option "NaturalScrolling" "true"
    Option "DisableWhileTyping" "true"
    Option "AccelProfile" "adaptive"
EndSection

Section "InputClass"
    Identifier "mouse"
    Driver "libinput"
    MatchIsPointer "on"
    Option "AccelProfile" "flat"
    Option "AccelSpeed" "0"
EndSection

Section "InputClass"
    Identifier "keyboard"
    Driver "libinput"
    MatchIsKeyboard "on"
    Option "XkbOptions" "caps:escape"
EndSection
EOF

    # Systemd journal configuration
    install -d "${pkgdir}/etc/systemd"
    cat > "${pkgdir}/etc/systemd/journald.conf.d/orionos.conf" << 'EOF'
[Journal]
Storage=persistent
SystemMaxUse=500M
SystemMaxFileSize=50M
RuntimeMaxUse=100M
MaxRetentionSec=1week
ForwardToSyslog=no
EOF

    # Systemd logind configuration
    cat > "${pkgdir}/etc/systemd/logind.conf.d/orionos.conf" << 'EOF'
[Login]
HandlePowerKey=suspend
HandleLidSwitch=suspend
HandleLidSwitchExternalPower=suspend
HandleLidSwitchDocked=ignore
IdleAction=suspend
IdleActionSec=30min
EOF

    # Pacman configuration
    cat > "${pkgdir}/etc/pacman.d/orionos-mirrorlist" << 'EOF'
##
## OrionOS Mirror List
##

# Worldwide
Server = https://repo.orionos.org/$repo/os/$arch
Server = https://mirror.orionos.org/$repo/os/$arch

# North America
Server = https://na.mirror.orionos.org/$repo/os/$arch

# Europe
Server = https://eu.mirror.orionos.org/$repo/os/$arch

# Asia
Server = https://asia.mirror.orionos.org/$repo/os/$arch
EOF

    log_info "OrionOS configuration installed"
}
