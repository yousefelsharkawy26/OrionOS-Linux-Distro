#!/bin/bash
# OrionOS Container App Launcher
set -euo pipefail

CONFIG_FILE="/etc/orionos/containers.conf"

launch_container() {
    local app_name="$1"
    local container_img="${2:-}"

    if [[ -z "$container_img" ]]; then
        container_img="ghcr.io/orionos/apps/${app_name}:latest"
    fi

    echo "Launching ${app_name} from container..."
    podman run --rm -it \
        --name "orionos-${app_name}" \
        --hostname "orionos-${app_name}" \
        -e DISPLAY="${DISPLAY}" \
        -e WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
        -e XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}" \
        -v /tmp/.X11-unix:/tmp/.X11-unix:ro \
        -v "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}:${XDG_RUNTIME_DIR:-/run/user/$(id -u)}:ro" \
        --device /dev/dri:/dev/dri \
        --network host \
        --privileged \
        "${container_img}"
}

launch_distrobox() {
    local distro="$1"
    local command="${2:-bash}"

    echo "Launching Distrobox: ${distro}..."
    distrobox enter --name "orionos-${distro}" -- "${command}"
}

list_apps() {
    echo "=== Available Container Apps ==="
    echo ""
    echo "  Web Browsers:"
    echo "    firefox       Mozilla Firefox"
    echo "    chromium      Chromium Browser"
    echo "    brave         Brave Browser"
    echo "    tor           Tor Browser"
    echo ""
    echo "  Development:"
    echo "    code          Visual Studio Code"
    echo "    eclipse       Eclipse IDE"
    echo "    android-studio Android Studio"
    echo "    godot         Godot Engine"
    echo ""
    echo "  Creative:"
    echo "    gimp          GIMP Image Editor"
    echo "    inkscape      Inkscape Vector Editor"
    echo "    blender       Blender 3D"
    echo "    kdenlive      Kdenlive Video Editor"
    echo "    audacity      Audacity Audio Editor"
    echo ""
    echo "  Office:"
    echo "    libreoffice   LibreOffice Suite"
    echo "    obsidian      Obsidian Notes"
    echo ""
    echo "  Gaming:"
    echo "    steam         Steam (containerized)"
    echo "    lutris        Lutris Game Manager"
    echo ""
    echo "  System:"
    echo "    htop          System Monitor"
    echo "    neofetch      System Info"
    echo "    gparted       Partition Manager"
}

case "${1:-}" in
    app)       launch_container "${2:?App name required}" "${3:-}" ;;
    distrobox) launch_distrobox "${2:?Distro required}" "${3:-bash}" ;;
    list)      list_apps ;;
    *)         echo "Usage: $0 {app|distrobox|list} [name] [image/distro]"; exit 1 ;;
esac
